<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kodiak — Card Scanner & Outreach</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black:   #080c12;
  --dark1:   #0d1117;
  --dark2:   #0f1923;
  --dark3:   #161f2e;
  --dark4:   #1c2a3d;
  --gold:    #b8952a;
  --gold2:   #d4aa45;
  --goldDim: rgba(184,149,42,0.10);
  --white:   #ffffff;
  --off:     #e8e0d0;
  --gray:    #5a6478;
  --lgray:   #8a95a8;
  --border:  rgba(184,149,42,0.15);
  --green:   #4ade80;
  --greenDim: rgba(74,222,128,0.1);
  --red:     #f87171;
  --blue:    #60a5fa;
}

*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
background: var(–black);
color: var(–off);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
overflow-x: hidden;
}

body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 512 512’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.75’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.03’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 0;
}

/* HEADER */
.app-header {
position: sticky;
top: 0;
z-index: 100;
background: rgba(8,12,18,0.96);
backdrop-filter: blur(20px);
border-bottom: 1px solid var(–border);
padding: 0 28px;
display: flex;
align-items: center;
justify-content: space-between;
height: 56px;
}
.header-left { display: flex; align-items: center; gap: 12px; }
.brand-mark { font-family: ‘DM Mono’, monospace; font-size: 13px; font-weight: 500; letter-spacing: 0.3em; color: var(–gold); }
.brand-sep { width: 1px; height: 16px; background: var(–border); }
.brand-tool { font-family: ‘DM Mono’, monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(–lgray); }
.header-back { font-family: ‘DM Mono’, monospace; font-size: 10px; letter-spacing: 0.1em; color: var(–lgray); text-decoration: none; transition: color 0.2s; }
.header-back:hover { color: var(–gold); }

/* TABS */
.tab-bar {
position: sticky;
top: 56px;
z-index: 90;
background: var(–dark1);
border-bottom: 1px solid var(–border);
padding: 0 28px;
display: flex;
gap: 0;
}
.tab-btn {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gray);
padding: 16px 24px;
border: none;
background: none;
cursor: pointer;
border-bottom: 2px solid transparent;
transition: all 0.2s;
display: flex;
align-items: center;
gap: 8px;
}
.tab-btn:hover { color: var(–lgray); }
.tab-btn.active { color: var(–gold); border-bottom-color: var(–gold); }
.tab-count {
background: var(–goldDim);
color: var(–gold);
font-size: 9px;
padding: 2px 7px;
border-radius: 10px;
font-weight: 500;
}

/* PANELS */
.panel { display: none; padding: 32px 28px; }
.panel.active { display: block; animation: fadeIn 0.25s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

/* SCANNER */
.scanner-wrap {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px;
align-items: start;
}

.upload-zone {
background: var(–dark2);
border: 2px dashed var(–border);
border-radius: 12px;
padding: 48px 24px;
text-align: center;
cursor: pointer;
transition: all 0.25s;
position: relative;
overflow: hidden;
}
.upload-zone:hover { border-color: var(–gold); background: var(–dark3); }
.upload-zone.drag-over { border-color: var(–gold); background: var(–goldDim); }

.upload-icon { font-size: 40px; margin-bottom: 16px; opacity: 0.5; }
.upload-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: 22px;
font-weight: 300;
color: var(–white);
margin-bottom: 8px;
}
.upload-title em { font-style: italic; color: var(–gold); }
.upload-sub { font-size: 13px; color: var(–lgray); line-height: 1.6; margin-bottom: 20px; }
.upload-btn {
background: var(–gold);
color: var(–black);
border: none;
border-radius: 5px;
padding: 10px 24px;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
font-weight: 500;
letter-spacing: 0.15em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}
.upload-btn:hover { background: var(–gold2); }
.upload-input { display: none; }

.card-preview {
background: var(–dark2);
border: 1px solid var(–border);
border-radius: 12px;
overflow: hidden;
}
.preview-header {
background: var(–dark3);
padding: 16px 20px;
border-bottom: 1px solid var(–border);
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
}
.preview-img-wrap {
padding: 16px;
min-height: 160px;
display: flex;
align-items: center;
justify-content: center;
}
.preview-img {
max-width: 100%;
max-height: 200px;
border-radius: 6px;
object-fit: contain;
display: none;
}
.preview-placeholder {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.1em;
color: var(–gray);
text-align: center;
}

.extracted-fields {
display: none;
padding: 16px 20px;
border-top: 1px solid var(–border);
}
.extracted-fields.visible { display: block; }

.field-row {
display: flex;
align-items: center;
gap: 12px;
padding: 8px 0;
border-bottom: 1px solid rgba(255,255,255,0.03);
}
.field-row:last-child { border-bottom: none; }
.field-key {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–gray);
width: 80px;
flex-shrink: 0;
}
.field-val-input {
flex: 1;
background: var(–dark4);
border: 1px solid rgba(255,255,255,0.04);
border-radius: 4px;
padding: 7px 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
color: var(–white);
outline: none;
transition: border-color 0.2s;
}
.field-val-input:focus { border-color: var(–gold); }
.field-val-input::placeholder { color: var(–gray); }

.scanner-actions {
padding: 16px 20px;
border-top: 1px solid var(–border);
display: none;
gap: 10px;
}
.scanner-actions.visible { display: flex; }

.btn-primary {
background: var(–gold);
color: var(–black);
border: none;
border-radius: 6px;
padding: 11px 24px;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
font-weight: 500;
letter-spacing: 0.15em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
flex: 1;
}
.btn-primary:hover { background: var(–gold2); }
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }

.btn-secondary {
background: var(–dark4);
color: var(–lgray);
border: 1px solid var(–border);
border-radius: 6px;
padding: 11px 18px;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}
.btn-secondary:hover { border-color: var(–gold); color: var(–gold); }

/* LOADING SPINNER */
.scan-loading {
display: none;
padding: 32px;
text-align: center;
}
.scan-loading.visible { display: block; }
.spin-ring {
width: 40px;
height: 40px;
border: 2px solid rgba(184,149,42,0.15);
border-top-color: var(–gold);
border-radius: 50%;
animation: spin 0.8s linear infinite;
margin: 0 auto 12px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.scan-loading-text {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gold);
}

/* BATCH QUEUE */
.batch-queue { margin-top: 16px; }
.batch-label { font-family: ‘DM Mono’, monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(–gold); margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; }
.batch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px; }
.batch-thumb { position: relative; border-radius: 4px; overflow: hidden; border: 1px solid var(–border); aspect-ratio: 1.6; cursor: pointer; }
.batch-thumb img { width: 100%; height: 100%; object-fit: cover; }
.batch-thumb .batch-status { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 18px; background: rgba(8,12,18,0.6); }
.batch-thumb .batch-remove { position: absolute; top: 2px; right: 2px; background: rgba(248,113,113,0.8); border: none; border-radius: 50%; width: 16px; height: 16px; font-size: 9px; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.batch-process-btn { width: 100%; margin-top: 10px; background: var(–gold); color: var(–black); border: none; border-radius: 4px; padding: 11px; font-family: ‘DM Mono’, monospace; font-size: 10px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.batch-process-btn:hover { background: var(–gold2); }
.batch-process-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* OUTREACH CARD GRID */
.outreach-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
.biz-card { background: var(–dark2); border: 1px solid var(–border); border-radius: 8px; padding: 18px 20px; transition: border-color 0.2s; animation: fadeIn 0.3s ease; position: relative; overflow: hidden; }
.biz-card::before { content: ‘’; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(–gold); opacity: 0; transition: opacity 0.2s; }
.biz-card:hover { border-color: rgba(184,149,42,0.3); }
.biz-card:hover::before { opacity: 1; }
.biz-card.emailed { border-left: 3px solid var(–gold); }
.biz-card.converted { opacity: 0.5; }
.biz-card-name { font-size: 15px; font-weight: 600; color: var(–white); margin-bottom: 2px; }
.biz-card-biz { font-family: ‘DM Mono’, monospace; font-size: 10px; color: var(–gold); letter-spacing: 0.06em; margin-bottom: 10px; }
.biz-card-details { display: flex; flex-direction: column; gap: 3px; margin-bottom: 12px; }
.biz-card-detail { font-family: ‘DM Mono’, monospace; font-size: 10px; color: var(–lgray); }
.biz-card-detail a { color: var(–lgray); text-decoration: none; }
.biz-card-detail a:hover { color: var(–gold); }
.biz-card-status { font-family: ‘DM Mono’, monospace; font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; padding: 2px 8px; border-radius: 10px; display: inline-block; margin-bottom: 10px; }
.biz-card-actions { display: flex; gap: 5px; flex-wrap: wrap; }
.biz-card-btn { font-family: ‘DM Mono’, monospace; font-size: 8px; letter-spacing: 0.06em; text-transform: uppercase; padding: 5px 10px; border-radius: 3px; background: var(–dark3); border: 1px solid rgba(255,255,255,0.06); color: var(–lgray); cursor: pointer; transition: all 0.2s; }
.biz-card-btn:hover { border-color: var(–gold); color: var(–gold); }
.biz-card-btn.success:hover { border-color: var(–green); color: var(–green); }
.biz-card-btn.danger:hover { border-color: var(–red); color: var(–red); }
.biz-card-notes { font-size: 11px; color: var(–gray); margin-top: 8px; font-style: italic; line-height: 1.5; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.04); }

@media(max-width: 600px) {
.outreach-grid { grid-template-columns: 1fr; }
}
.section-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 20px;
flex-wrap: wrap;
gap: 12px;
}
.section-label {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–gold);
display: flex;
align-items: center;
gap: 12px;
}
.section-label::after { content: ‘’; width: 40px; height: 1px; background: var(–border); }

.outreach-card {
background: var(–dark2);
border: 1px solid var(–border);
border-radius: 10px;
padding: 20px 24px;
margin-bottom: 12px;
display: grid;
grid-template-columns: 1fr auto;
gap: 16px;
align-items: start;
transition: border-color 0.2s;
animation: fadeIn 0.3s ease;
}
.outreach-card:hover { border-color: rgba(184,149,42,0.3); }
.outreach-card.emailed { border-left: 3px solid var(–gold); }
.outreach-card.converted { border-left: 3px solid var(–green); opacity: 0.6; }

.contact-name {
font-size: 16px;
font-weight: 500;
color: var(–white);
margin-bottom: 2px;
}
.contact-biz {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gold);
letter-spacing: 0.06em;
margin-bottom: 8px;
}
.contact-details {
display: flex;
gap: 16px;
flex-wrap: wrap;
}
.contact-detail {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.05em;
color: var(–lgray);
}
.contact-detail a { color: var(–lgray); text-decoration: none; }
.contact-detail a:hover { color: var(–gold); }

.outreach-status {
font-family: ‘DM Mono’, monospace;
font-size: 8px;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 3px 9px;
border-radius: 10px;
white-space: nowrap;
margin-bottom: 10px;
display: inline-block;
}
.status-cold { background: rgba(96,165,250,0.1); color: var(–blue); }
.status-emailed { background: rgba(184,149,42,0.12); color: var(–gold); }
.status-replied { background: rgba(74,222,128,0.12); color: var(–green); }
.status-converted { background: rgba(74,222,128,0.2); color: var(–green); border: 1px solid rgba(74,222,128,0.3); }

.card-actions { display: flex; flex-direction: column; gap: 6px; align-items: flex-end; }
.action-btn {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 4px;
padding: 6px 12px;
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(–lgray);
cursor: pointer;
transition: all 0.2s;
white-space: nowrap;
}
.action-btn:hover { border-color: var(–gold); color: var(–gold); }
.action-btn.primary { background: var(–goldDim); border-color: var(–border); color: var(–gold); }
.action-btn.success { background: var(–greenDim); border-color: rgba(74,222,128,0.2); color: var(–green); }
.action-btn.danger:hover { border-color: var(–red); color: var(–red); }

/* EMAIL COMPOSE */
.compose-modal {
display: none;
position: fixed;
inset: 0;
background: rgba(8,12,18,0.9);
backdrop-filter: blur(12px);
z-index: 200;
align-items: center;
justify-content: center;
padding: 20px;
}
.compose-modal.visible { display: flex; }

.compose-card {
background: var(–dark2);
border: 1px solid var(–border);
border-top: 2px solid var(–gold);
border-radius: 12px;
padding: 32px;
width: 100%;
max-width: 640px;
max-height: 90vh;
overflow-y: auto;
animation: modalIn 0.25s ease;
}
@keyframes modalIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

.compose-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 20px;
}
.compose-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: 24px;
font-weight: 300;
color: var(–white);
}
.compose-title em { font-style: italic; color: var(–gold); }
.compose-close { background: none; border: none; color: var(–gray); font-size: 20px; cursor: pointer; }
.compose-close:hover { color: var(–white); }

.compose-to {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 6px;
padding: 10px 14px;
font-family: ‘DM Mono’, monospace;
font-size: 12px;
color: var(–lgray);
margin-bottom: 12px;
}

.compose-subject {
width: 100%;
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 6px;
padding: 10px 14px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
color: var(–white);
outline: none;
transition: border-color 0.2s;
margin-bottom: 12px;
}
.compose-subject:focus { border-color: var(–gold); }

.compose-body {
width: 100%;
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 6px;
padding: 14px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
color: var(–off);
outline: none;
resize: vertical;
min-height: 260px;
line-height: 1.7;
transition: border-color 0.2s;
margin-bottom: 16px;
}
.compose-body:focus { border-color: var(–gold); }

.compose-actions { display: flex; gap: 10px; }

/* EMPTY */
.empty-state {
text-align: center;
padding: 64px 24px;
}
.empty-icon { font-size: 48px; opacity: 0.2; margin-bottom: 16px; }
.empty-text {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gray);
margin-bottom: 20px;
}

/* TOOLBAR */
.list-toolbar {
display: flex;
gap: 10px;
margin-bottom: 20px;
flex-wrap: wrap;
align-items: center;
}
.search-input {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 6px;
padding: 9px 14px;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
color: var(–white);
outline: none;
transition: border-color 0.2s;
flex: 1;
min-width: 160px;
}
.search-input:focus { border-color: var(–gold); }
.search-input::placeholder { color: var(–gray); }
.filter-select {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 6px;
padding: 9px 14px;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.08em;
color: var(–lgray);
outline: none;
cursor: pointer;
transition: border-color 0.2s;
}
.filter-select:focus { border-color: var(–gold); }
.filter-select option { background: var(–dark2); }

.export-btn {
background: var(–dark3);
border: 1px solid var(–border);
border-radius: 6px;
padding: 9px 16px;
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–lgray);
cursor: pointer;
transition: all 0.2s;
white-space: nowrap;
}
.export-btn:hover { border-color: var(–gold); color: var(–gold); }

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(–dark1); }
::-webkit-scrollbar-thumb { background: var(–dark4); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(–gold); }

@media(max-width: 768px) {
.scanner-wrap { grid-template-columns: 1fr; }
.app-header { padding: 0 16px; }
.tab-bar { padding: 0 16px; }
.panel { padding: 20px 16px; }
}
</style>

</head>
<body>

<!-- EMAIL COMPOSE MODAL -->

<div class="compose-modal" id="composeModal">
  <div class="compose-card">
    <div class="compose-header">
      <div class="compose-title">Compose <em>Email</em></div>
      <button class="compose-close" onclick="closeCompose()">✕</button>
    </div>
    <div class="compose-to" id="composeTo">To: —</div>
    <input type="text" class="compose-subject" id="composeSubject" placeholder="Subject line..." />
    <textarea class="compose-body" id="composeBody"></textarea>
    <div class="compose-actions">
      <button class="btn-secondary" onclick="closeCompose()">Cancel</button>
      <button class="btn-primary" onclick="copyEmail()">Copy Email</button>
      <button class="btn-primary" onclick="markEmailed()" style="background:var(--dark4);color:var(--gold);border:1px solid var(--gold);">Mark as Sent</button>
    </div>
  </div>
</div>

<!-- HEADER -->

<header class="app-header">
  <div class="header-left">
    <span class="brand-mark">KODIAK</span>
    <div class="brand-sep"></div>
    <span class="brand-tool">Card Scanner & Outreach</span>
  </div>
  <a href="kodiak-command-center.html" class="header-back">← Command Center</a>
</header>

<!-- TABS -->

<div class="tab-bar">
  <button class="tab-btn active" id="tabScan" onclick="switchTab('scan')">📷 Scan Card</button>
  <button class="tab-btn" id="tabOutreach" onclick="switchTab('outreach')">📨 Cold Outreach <span class="tab-count" id="countOutreach">0</span></button>
  <button class="tab-btn" id="tabConverted" onclick="switchTab('converted')">✓ Converted <span class="tab-count" id="countConverted">0</span></button>
</div>

<!-- SCAN PANEL -->

<div class="panel active" id="panelScan">

  <!-- PHOTO CAPTURE BUTTONS -->

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
    <button onclick="document.getElementById('cardInputCamera').click()" style="background:#C6A85A;color:#0B0B0B;border:none;border-radius:6px;padding:16px;font-family:'DM Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;">
      📷 Take Photo
    </button>
