<script>
// ── SUPABASE ──
const SUPABASE_URL = 'https://flhnntxmikmppcoucdky.supabase.co';
const getKey = () => localStorage.getItem('kodiak_supabase_key') || '';

async function getClaudeKey() {
  // Try Supabase first
  const sbKey = getKey();
  if (sbKey) {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/config?id=eq.claude_api_key&select=value`, {
        headers: { 'apikey': sbKey, 'Authorization': `Bearer ${sbKey}` }
      });
      if (res.ok) {
        const data = await res.json();
        if (data && data.length && data[0].value) {
          localStorage.setItem('kodiak_claude_key', data[0].value);
          return data[0].value;
        }
      }
    } catch(e) {}
  }
  // Fall back to localStorage
  return localStorage.getItem('kodiak_claude_key') || '';
}

async function sbPost(table, data) {
  const key = getKey();
  if (!key) return;
  await fetch(`${SUPABASE_URL}/rest/v1/${table}`, {
    method: 'POST',
    headers: { 'apikey': key, 'Authorization': `Bearer ${key}`, 'Content-Type': 'application/json', 'Prefer': 'resolution=merge-duplicates' },
    body: JSON.stringify(Array.isArray(data) ? data : [data])
  });
}

async function sbLoad(table, order = 'added_at') {
  const key = getKey();
  if (!key) return null;
  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}?order=${order}.desc`, {
      headers: { 'apikey': key, 'Authorization': `Bearer ${key}` }
    });
    if (res.ok) return res.json();
  } catch(e) {}
  return null;
}

// ── DATA ──
let contacts = JSON.parse(localStorage.getItem('kodiak_contacts') || '[]');
let activeComposeId = null;
let currentImageBase64 = null;

async function save() {
  localStorage.setItem('kodiak_contacts', JSON.stringify(contacts));
  if (getKey()) await sbPost('contacts', contacts);
}

function genId() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }

async function loadContacts() {
  const data = await sbLoad('contacts', 'added_at');
  if (data && data.length) {
    contacts = data;
    localStorage.setItem('kodiak_contacts', JSON.stringify(contacts));
  }
}

// ── TABS ──
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
  document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
  if (tab === 'outreach') renderOutreach();
  if (tab === 'converted') renderConverted();
  updateCounts();
}

function updateCounts() {
  const outreach = contacts.filter(c => c.status !== 'converted').length;
  const converted = contacts.filter(c => c.status === 'converted').length;
  document.getElementById('countOutreach').textContent = outreach;
  document.getElementById('countConverted').textContent = converted;
}

// ── MANUAL ENTRY ──
function openManualEntry() {
  ['ex_name','ex_title','ex_business','ex_email','ex_phone','ex_website','ex_city','ex_notes'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('previewSection').style.display = 'none';
  document.getElementById('scanLoading').classList.remove('visible');
  document.getElementById('extractedFields').classList.add('visible');
  document.getElementById('scannerActions').classList.add('visible');
  setTimeout(() => document.getElementById('ex_name').focus(), 100);
}

// ── FILE HANDLING ──
function handleFile(event) {
  const file = event.target.files[0];
  if (file) processImage(file);
}

function handleDrag(e) {
  e.preventDefault();
  document.getElementById('uploadZone').classList.add('drag-over');
}

function handleDrop(e) {
  e.preventDefault();
  document.getElementById('uploadZone').classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) processImage(file);
}

function processImage(file) {
  // Use canvas to convert any format (including HEIC) to JPEG
  const img = new Image();
  const objectUrl = URL.createObjectURL(file);
  img.onload = () => {
    const canvas = document.createElement('canvas');
    // Scale down if too large for API
    const maxSize = 1200;
    let w = img.width, h = img.height;
    if (w > maxSize || h > maxSize) {
      if (w > h) { h = Math.round(h * maxSize / w); w = maxSize; }
      else { w = Math.round(w * maxSize / h); h = maxSize; }
    }
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, w, h);
    const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
    currentImageBase64 = dataUrl.split(',')[1];

    // Show preview
    const previewImg = document.getElementById('previewImg');
    previewImg.src = dataUrl;
    document.getElementById('previewSection').style.display = 'block';

    URL.revokeObjectURL(objectUrl);
    extractCard(currentImageBase64);
  };
  img.onerror = () => {
    // Fallback to FileReader
    const reader = new FileReader();
    reader.onload = (e) => {
      currentImageBase64 = e.target.result.split(',')[1];
      const previewImg = document.getElementById('previewImg');
      previewImg.src = e.target.result;
      previewImg.style.display = 'block';
      document.getElementById('previewPlaceholder').style.display = 'none';
      extractCard(currentImageBase64);
    };
    reader.readAsDataURL(file);
  };
  img.src = objectUrl;
}

async function extractCard(base64) {
  document.getElementById('scanLoading').classList.add('visible');
  document.getElementById('extractedFields').classList.remove('visible');
  document.getElementById('scannerActions').classList.remove('visible');

  const claudeKey = await getClaudeKey();
  if (!claudeKey) {
    document.getElementById('scanLoading').classList.remove('visible');
    document.getElementById('extractedFields').classList.add('visible');
    document.getElementById('scannerActions').classList.add('visible');
    alert('Claude API key not set. Go to Kodiak-settings to add it.');
    return;
  }

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': claudeKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{
          role: 'user',
          content: [
            {
              type: 'image',
              source: { type: 'base64', media_type: 'image/jpeg', data: base64 }
            },
            {
              type: 'text',
              text: `Extract all contact information from this business card. Return JSON only — no explanation, no markdown:
{
  "name": "full name or null",
  "title": "job title or null",
  "business": "company name or null",
  "email": "email address or null",
  "phone": "phone number or null",
  "website": "website url or null",
  "city": "city and state or null",
  "industry": "best guess industry from card or null"
}`
            }
          ]
        }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(b => b.text || '').join('') || '';
    const clean = text.replace(/```json|```/g, '').trim();
    const extracted = JSON.parse(clean);

    document.getElementById('ex_name').value = extracted.name || '';
    document.getElementById('ex_title').value = extracted.title || '';
    document.getElementById('ex_business').value = extracted.business || '';
    document.getElementById('ex_email').value = extracted.email || '';
    document.getElementById('ex_phone').value = extracted.phone || '';
    document.getElementById('ex_website').value = extracted.website || '';
    document.getElementById('ex_city').value = extracted.city || '';

  } catch (err) {
    console.log('Extraction failed — manual entry mode', err);
  }

  document.getElementById('extractedFields').classList.add('visible');
  document.getElementById('scannerActions').classList.add('visible');
  document.getElementById('scanLoading').classList.remove('visible');
}

function addToOutreach() {
  const contact = {
    id: genId(),
    name: document.getElementById('ex_name').value,
    title: document.getElementById('ex_title').value,
    business: document.getElementById('ex_business').value,
    email: document.getElementById('ex_email').value,
    phone: document.getElementById('ex_phone').value,
    website: document.getElementById('ex_website').value,
    city: document.getElementById('ex_city').value,
    notes: document.getElementById('ex_notes').value,
    status: 'cold',
    source: 'Business Card',
    addedAt: Date.now(),
    activity: []
  };

  contacts.unshift(contact);
  save();
  updateCounts();
  resetScanner();
  switchTab('outreach');
}

function resetScanner() {
  document.getElementById('previewSection').style.display = 'none';
  document.getElementById('previewImg').src = '';
  document.getElementById('extractedFields').classList.remove('visible');
  document.getElementById('scannerActions').classList.remove('visible');
  document.getElementById('scanLoading').classList.remove('visible');
  document.getElementById('cardInputCamera').value = '';
  document.getElementById('cardInputLibrary').value = '';
  currentImageBase64 = null;
  ['ex_name','ex_title','ex_business','ex_email','ex_phone','ex_website','ex_city','ex_notes'].forEach(id => {
    document.getElementById(id).value = '';
  });
}

// ── BATCH QUEUE ──
let batchQueue = []; // [{base64, dataUrl, status}]

function handleFile(event) {
  const file = event.target.files[0];
  if (file) processImage(file);
}

function handleFiles(event) {
  const files = Array.from(event.target.files);
  if (!files.length) return;

  if (files.length === 1) {
    // Single card — use existing single scan flow
    processImage(files[0]);
    return;
  }

  // Multiple cards — add to batch queue
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = (e) => {
      const dataUrl = e.target.result;
      const base64 = dataUrl.split(',')[1];
      batchQueue.push({ base64, dataUrl, status: 'pending' });
      renderBatchQueue();
    };
    reader.readAsDataURL(file);
  });
}

function renderBatchQueue() {
  const queue = document.getElementById('batchQueue');
  const grid = document.getElementById('batchGrid');
  const count = document.getElementById('batchCount');
  if (!batchQueue.length) { queue.style.display = 'none'; return; }
  queue.style.display = 'block';
  count.textContent = batchQueue.length;
  grid.innerHTML = batchQueue.map((item, i) => `
    <div class="batch-thumb">
      <img src="${item.dataUrl}" />
      <div class="batch-status">${item.status === 'pending' ? '⏳' : item.status === 'processing' ? '🔄' : item.status === 'done' ? '✓' : '❌'}</div>
      <button class="batch-remove" onclick="removeBatchItem(${i})">✕</button>
    </div>
  `).join('');
}

function removeBatchItem(i) {
  batchQueue.splice(i, 1);
  renderBatchQueue();
}

async function processBatch() {
  const claudeKey = await getClaudeKey();
  if (!claudeKey) {
    alert('Claude API key not set. Go to Settings and add your Claude API key.');
    return;
  }
  const btn = document.getElementById('batchProcessBtn');
  btn.disabled = true;
  btn.textContent = `Processing 0 of ${batchQueue.length}...`;

  for (let i = 0; i < batchQueue.length; i++) {
    const item = batchQueue[i];
    if (item.status === 'done') continue;
    item.status = 'processing';
    renderBatchQueue();
    btn.textContent = `Processing ${i + 1} of ${batchQueue.length}...`;

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': claudeKey,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true'
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          messages: [{
            role: 'user',
            content: [
              { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: item.base64 } },
              { type: 'text', text: `Extract all contact information from this business card. Return JSON only:\n{"name":"full name or null","title":"job title or null","business":"company name or null","email":"email or null","phone":"phone or null","website":"website or null","city":"city and state or null","industry":"industry or null"}` }
            ]
          }]
        })
      });
      const data = await response.json();
      if (data.error) throw new Error(data.error.message);
      const text = data.content?.map(b => b.text || '').join('') || '';
      const clean = text.replace(/```json|```/g, '').trim();
      const extracted = JSON.parse(clean);
      const contact = {
        id: genId(),
        name: extracted.name || '',
        title: extracted.title || '',
        business: extracted.business || '',
        email: extracted.email || '',
        phone: extracted.phone || '',
        website: extracted.website || '',
        city: extracted.city || '',
        notes: '',
        status: 'cold',
        source: 'Business Card',
        addedAt: Date.now(),
        activity: []
      };
      contacts.unshift(contact);
      await save();
      item.status = 'done';
    } catch(e) {
      console.error('Batch item error:', e);
      item.status = 'error';
    }
    renderBatchQueue();
    await new Promise(r => setTimeout(r, 800));
  }

  btn.textContent = `✓ ${batchQueue.filter(i=>i.status==='done').length} cards added to outreach`;
  btn.disabled = false;
  updateCounts();
  setTimeout(() => {
    batchQueue = [];
    renderBatchQueue();
    btn.textContent = 'Process All Cards →';
    switchTab('outreach');
  }, 2000);
}
// ── OUTREACH LIST ──
function renderOutreach() {
  const search = document.getElementById('outreachSearch').value.toLowerCase();
  const filter = document.getElementById('outreachFilter').value;

  const filtered = contacts.filter(c => {
    if (c.status === 'converted') return false;
    if (filter && c.status !== filter) return false;
    if (search) return (c.name + c.business + c.email + c.city).toLowerCase().includes(search);
    return true;
  });

  const list = document.getElementById('outreachList');
  const empty = document.getElementById('outreachEmpty');

  if (!filtered.length) {
    list.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  list.innerHTML = `<div class="outreach-grid">${filtered.map(c => `
    <div class="biz-card ${c.status === 'emailed' ? 'emailed' : ''}" id="card_${c.id}">
      <div class="biz-card-name">${c.name || '—'}</div>
      <div class="biz-card-biz">${c.business || ''}${c.title ? ' · ' + c.title : ''}</div>
      <span class="biz-card-status status-${c.status}">${c.status === 'cold' ? 'Not Contacted' : c.status === 'emailed' ? 'Email Sent' : 'Replied'}</span>
      <div class="biz-card-details">
        ${c.email ? `<span class="biz-card-detail">✉ <a href="mailto:${c.email}">${c.email}</a></span>` : ''}
        ${c.phone ? `<span class="biz-card-detail">📞 <a href="tel:${c.phone}">${c.phone}</a></span>` : ''}
        ${c.city ? `<span class="biz-card-detail">📍 ${c.city}</span>` : ''}
        ${c.website ? `<span class="biz-card-detail">🌐 <a href="${c.website}" target="_blank">${c.website.replace(/https?:\/\//,'')}</a></span>` : ''}
      </div>
      ${c.notes ? `<div class="biz-card-notes">${c.notes}</div>` : ''}
      <div class="biz-card-actions">
        <button class="biz-card-btn" onclick="openCompose('${c.id}')">✉ Email</button>
        <button class="biz-card-btn success" onclick="markReplied('${c.id}')">↩ Replied</button>
        <button class="biz-card-btn success" onclick="convertToLead('${c.id}')">→ Lead</button>
        <button class="biz-card-btn danger" onclick="deleteContact('${c.id}')">✕</button>
      </div>
    </div>
  `).join('')}</div>`;
}

function renderConverted() {
  const converted = contacts.filter(c => c.status === 'converted');
  const list = document.getElementById('convertedList');
  const empty = document.getElementById('convertedEmpty');

  if (!converted.length) {
    list.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  list.innerHTML = converted.map(c => `
    <div class="outreach-card converted">
      <div>
        <div class="contact-name">${c.name || '—'}</div>
        <div class="contact-biz">${c.business || ''}${c.title ? ' · ' + c.title : ''}</div>
        <div class="contact-details">
          ${c.email ? `<span class="contact-detail">${c.email}</span>` : ''}
          ${c.phone ? `<span class="contact-detail">${c.phone}</span>` : ''}
          ${c.city ? `<span class="contact-detail">📍 ${c.city}</span>` : ''}
        </div>
      </div>
      <div class="card-actions">
        <span class="outreach-status status-converted">Converted to Lead</span>
        <div style="font-family:'DM Mono',monospace;font-size:9px;color:var(--gray);text-align:right;">Added to Lead Tracker</div>
      </div>
    </div>
  `).join('');
}

// ── ACTIONS ──
function markReplied(id) {
  const c = contacts.find(x => x.id === id);
  if (!c) return;
  c.status = 'replied';
  if (!c.activity) c.activity = [];
  c.activity.push({ date: Date.now(), note: 'Marked as replied' });
  save();
  renderOutreach();
  updateCounts();
}

function convertToLead(id) {
  const c = contacts.find(x => x.id === id);
  if (!c) return;
  c.status = 'converted';
  if (!c.activity) c.activity = [];
  c.activity.push({ date: Date.now(), note: 'Converted to lead' });

  const newLead = {
    id: 'lead_' + id,
    name: c.name, business: c.business,
    industry: c.industry || '', city: c.city,
    phone: c.phone, email: c.email,
    status: 'Warm', deal_value: 1000,
    source: 'Business Card',
    follow_up_date: new Date(Date.now() + 86400000 * 3).toISOString().split('T')[0],
    notes: `Converted from business card scan. Title: ${c.title || '—'}`,
    activity: [{ date: Date.now(), note: 'Added from card scanner — converted to lead' }],
    created_at: Date.now()
  };

  // Write to Supabase leads
  if (getKey()) sbPost('leads', newLead);

  // Also update localStorage for lead tracker fallback
  const localLeads = JSON.parse(localStorage.getItem('kodiak_leads') || '[]');
  localLeads.unshift({ ...newLead, dealValue: 1000, followUpDate: newLead.follow_up_date, createdAt: newLead.created_at });
  localStorage.setItem('kodiak_leads', JSON.stringify(localLeads));

  save();
  renderOutreach();
  renderConverted();
  updateCounts();

  // Show confirmation
  const btn = document.querySelector(`#card_${id} .action-btn.success`);
  if (btn) { btn.textContent = '✓ Added to Lead Tracker'; btn.style.color = 'var(--green)'; }
}

function deleteContact(id) {
  if (!confirm('Remove this contact?')) return;
  contacts = contacts.filter(c => c.id !== id);
  save();
  renderOutreach();
  updateCounts();
}

// ── EMAIL COMPOSE ──
function openCompose(id) {
  const c = contacts.find(x => x.id === id);
  if (!c) return;
  activeComposeId = id;

  document.getElementById('composeTo').textContent = `To: ${c.name || 'Contact'}${c.email ? ' <' + c.email + '>' : ' — no email on file'}`;
  document.getElementById('composeSubject').value = `Quick question about your business — Kodiak Strategy`;
  document.getElementById('composeBody').value = generateEmail(c);
  document.getElementById('composeModal').classList.add('visible');
}

function generateEmail(c) {
  const first = c.name?.split(' ')[0] || 'there';
  return `Hi ${first},

I came across your card recently and wanted to reach out.

I run Kodiak Strategy — we help businesses across the Northern Plains find exactly where AI can save them time and money. We do a structured assessment of your operation and deliver a written report showing every opportunity with projected ROI.

Guaranteed to identify at least 5 hours returned per week and $1,000 in monthly recoverable value — or the fee is fully refunded.

Would you be open to a quick 15-minute discovery call to see if it might be a fit for ${c.business || 'your business'}?

Best,
Ryan Fagerstrom
Founder & AI Consultant — Kodiak Strategy
(605) 605-2558
kodiakstrategy.com`;
}

function copyEmail() {
  const subject = document.getElementById('composeSubject').value;
  const body = document.getElementById('composeBody').value;
  const full = `Subject: ${subject}\n\n${body}`;
  navigator.clipboard.writeText(full).then(() => {
    const btn = document.querySelector('.compose-actions .btn-primary');
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = orig, 2000);
  });
}

function markEmailed() {
  if (!activeComposeId) return;
  const c = contacts.find(x => x.id === activeComposeId);
  if (!c) return;
  c.status = 'emailed';
  if (!c.activity) c.activity = [];
  c.activity.push({ date: Date.now(), note: `Email sent: ${document.getElementById('composeSubject').value}` });
  save();
  renderOutreach();
  updateCounts();
  closeCompose();
}

function closeCompose() {
  document.getElementById('composeModal').classList.remove('visible');
  activeComposeId = null;
}

// ── EXPORT ──
function exportCSV() {
  const rows = [['Name','Title','Business','Email','Phone','Website','City','Status','Added']];
  contacts.filter(c => c.status !== 'converted').forEach(c => {
    rows.push([c.name, c.title, c.business, c.email, c.phone, c.website, c.city, c.status, new Date(c.addedAt).toLocaleDateString()]);
  });
  const csv = rows.map(r => r.map(v => `"${(v||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
  a.download = `kodiak-outreach-${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
}

// ── INIT ──
async function init() {
  await loadContacts();
  updateCounts();
  renderOutreach();
}
init();
</script>

</body>
</html>
