        <input type="text" id="businessName" placeholder="Haley Optical" />
      </div>
    </div>
    <div class="form-row">
      <div class="field-group">
        <label class="field-label">Industry <span class="field-required">*</span></label>
        <select id="industry">
          <option value="" disabled selected>Select industry</option>
          <option>Optometry / Eye Care</option>
          <option>Dental Practice</option>
          <option>Medical / Healthcare</option>
          <option>Law Firm</option>
          <option>Accounting / Bookkeeping</option>
          <option>Insurance Agency</option>
          <option>Roofing / Construction</option>
          <option>HVAC / Home Services</option>
          <option>Real Estate</option>
          <option>Restaurant / Hospitality</option>
          <option>Other</option>
        </select>
      </div>
      <div class="field-group">
        <label class="field-label">Company Size</label>
        <select id="companySize">
          <option value="" disabled selected>Select size</option>
          <option>1-5 employees</option>
          <option>6-15 employees</option>
          <option>16-30 employees</option>
          <option>31-50 employees</option>
          <option>50+ employees</option>
        </select>
      </div>
    </div>
    <div class="field-group" style="margin-bottom:16px;">
      <label class="field-label">Main Pain Point / Goal</label>
      <input type="text" id="mainGoal" placeholder="Reducing manual insurance verification time" />
    </div>
  </div>

  <div class="form-section">
    <label class="field-label" style="display:block;margin-bottom:14px;">Staff Pay Rates <span style="color:var(--gray);font-size:9px;margin-left:8px;">Used for ROI calculations — collect during interview</span></label>
    <div class="rates-grid">
      <div class="rate-card">
        <div class="rate-label">Owner / Principal</div>
        <div class="rate-input-wrap">
          <span class="rate-symbol">$</span>
          <input type="number" class="rate-input" id="rateOwner" value="75" min="0" />
          <span style="font-family:'DM Mono',monospace;font-size:10px;color:var(--gray)">/hr</span>
        </div>
      </div>
      <div class="rate-card">
        <div class="rate-label">Admin / Office</div>
        <div class="rate-input-wrap">
          <span class="rate-symbol">$</span>
          <input type="number" class="rate-input" id="rateAdmin" value="18" min="0" />
          <span style="font-family:'DM Mono',monospace;font-size:10px;color:var(--gray)">/hr</span>
        </div>
      </div>
      <div class="rate-card">
