<!-- STEP 1: CLIENT INFO -->
<div class="step-panel active" id="step1">
  <div class="panel-header">
    <div class="panel-eyebrow">Step 01 — Client Information</div>
    <h1 class="panel-title">Who are we <em>assessing?</em></h1>
