<script>
let currentStep = 1;
let assessmentData = null;
let preflightData = null;

function goToStep(n) {
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.step-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('step' + n).classList.add('active');
  document.getElementById('sideStep' + n).classList.add('active');
  currentStep = n;
  window.scrollTo(0, 0);
}

function markDone(n) {
  document.getElementById('sideStep' + n).classList.add('done');
}

function updateCharCount() {
  const text = document.getElementById('transcriptText').value;
  const words = text.trim() ? text.trim().split(/\s+/).length : 0;
  document.getElementById('charCount').textContent = `${words.toLocaleString()} words`;
}

async function callClaude(messages, systemPrompt = '') {
  const body = {
    model: 'claude-sonnet-4-20250514',
    max_tokens: 1000,
    messages
  };
  if (systemPrompt) body.system = systemPrompt;

  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  const data = await response.json();
  return data.content?.map(b => b.text || '').join('') || '';
}

function parseJSON(text) {
  const clean = text.replace(/```json|```/g, '').trim();
  const start = clean.indexOf('{');
  const end = clean.lastIndexOf('}');
  if (start === -1 || end === -1) throw new Error('No JSON found');
  return JSON.parse(clean.slice(start, end + 1));
}

async function runPreflight() {
  const transcript = document.getElementById('transcriptText').value.trim();
  if (!transcript || transcript.split(/\s+/).length < 100) {
    document.getElementById('transcriptError').classList.add('visible');
    goToStep(2);
    return;
  }

  document.getElementById('preflightBtn').disabled = true;
  showLoading('Running pre-flight check...', 'Checking transcript quality and identifying key data points.');

  try {
    const raw = await callClaude([{
      role: 'user',
      content: `Run a pre-flight quality check on this business assessment transcript. Return JSON only:
{
  "detectedIndustry": "string",
  "detectedBusiness": "string or null",
  "wordCount": number,
  "painPointsFound": number,
  "dataQuality": "Excellent | Good | Fair | Poor",
  "readyForAnalysis": true/false,
  "notes": "one sentence"
}

TRANSCRIPT:
${transcript.slice(0, 3000)}`
    }]);

    preflightData = parseJSON(raw);

    const qEl = document.getElementById('pf_quality');
    const qualityClass = preflightData.dataQuality === 'Excellent' || preflightData.dataQuality === 'Good' ? 'good' : preflightData.dataQuality === 'Fair' ? 'warn' : 'bad';

    document.getElementById('pf_industry').textContent = preflightData.detectedIndustry || 'Unknown';
    document.getElementById('pf_business').textContent = preflightData.detectedBusiness || 'Not detected';
    document.getElementById('pf_words').textContent = preflightData.wordCount?.toLocaleString() || '—';
    document.getElementById('pf_painpoints').textContent = `${preflightData.painPointsFound} identified`;
    qEl.textContent = preflightData.dataQuality;
    qEl.className = `preflight-val ${qualityClass}`;
    document.getElementById('pf_ready').textContent = preflightData.readyForAnalysis ? 'Yes — ready to analyze' : 'More detail needed';

    document.getElementById('preflightResults').classList.add('visible');
    document.getElementById('preflightBtn').style.display = 'none';
    document.getElementById('analyzeBtn').style.display = 'inline-flex';
    markDone(3);

  } catch (err) {
    document.getElementById('preflightError').textContent = 'Pre-flight failed — check your connection and try again.';
    document.getElementById('preflightError').classList.add('visible');
    document.getElementById('preflightBtn').disabled = false;
  }

  hideLoading();
}

async function runAnalysis() {
  const transcript = document.getElementById('transcriptText').value.trim();
  const clientName = document.getElementById('clientName').value || 'Client';
  const businessName = document.getElementById('businessName').value || 'Business';
  const industry = document.getElementById('industry').value || 'General';
  const rateOwner = document.getElementById('rateOwner').value || 75;
  const rateAdmin = document.getElementById('rateAdmin').value || 18;
  const rateField = document.getElementById('rateField').value || 22;
  const rateSales = document.getElementById('rateSales').value || 25;

  showLoading('Running 5-pillar analysis...', 'This takes 30-60 seconds. Analyzing automation, lead generation, digital infrastructure, revenue ops, and process optimization.');
  goToStep(4);

  const systemPrompt = `You are an expert AI business consultant for Kodiak Strategy. Analyze transcripts and identify automation opportunities.

ROI FORMULA: Monthly Net ROI = (Hours Saved/Week × 4.33 × Role Rate) - Monthly Tool Cost
