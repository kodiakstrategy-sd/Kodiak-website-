RULES:
- Only recommend tools that ELIMINATE mental load, not relocate it
- Only Quick Wins if setup under 30 minutes
- If human judgment is the differentiator, do NOT automate that touchpoint
- Always check: does this remove friction or just speed up a broken process?
- Exactly 4 Quick Wins — no more, no less
- Be specific with numbers — use rates provided`;

  try {
    const raw = await callClaude([{
      role: 'user',
      content: `Analyze this assessment transcript for ${businessName} (${industry}). Return JSON only — no markdown:

{
  "summary": "2-3 sentence executive summary",
  "executiveSummary": {
    "pain": "main pain identified",
    "outcome": "projected outcome"
  },
  "roi": {
    "weeklyHoursSaved": number,
    "monthlyNetRoi": number,
    "monthlyToolCost": number,
    "paybackMonths": number
  },
  "recommendations": [
    {
      "painPoint": "string",
      "priority": "HIGH|MEDIUM|LOW",
      "quadrant": "Quick Win|Major Project|Fill-In|Deprioritize",
      "hoursLostPerWeek": number,
      "roleUsed": "string",
      "rateUsed": number,
      "toolName": "string",
      "toolDesc": "why it fits in one sentence",
      "monthlyCost": "string",
      "setupTime": "string",
      "monthlyNetRoi": number
    }
  ],
  "quickWins": [
    {
      "day": number,
      "toolName": "string",
      "task": "exact one-line instruction",
      "setupTime": "string",
      "timeSavedWeekly": "string"
    }
  ],
  "whatComesAfter": [
    {
      "title": "string",
      "desc": "string",
      "roi": "string",
      "kodiakFee": "string"
    }
  ],
  "processOptimization": [
    {
      "process": "string",
      "currentSteps": number,
      "recommendedSteps": number,
      "waste": "what to eliminate"
    }
  ],
  "totalAnnualOpportunity": number,
  "emailDraft": "complete email to send with report — professional, references their specific findings"
}

TRANSCRIPT:
${transcript.slice(0, 8000)}`
    }], systemPrompt);

    assessmentData = parseJSON(raw);
    renderAnalysis(assessmentData, businessName, clientName);
    markDone(4);

  } catch (err) {
    document.getElementById('analysisResults').innerHTML = `
      <div style="background:rgba(122,42,42,0.15);border:1px solid rgba(248,113,113,0.2);border-radius:8px;padding:20px;color:#f87171;">
        Analysis failed — ${err.message}. Try running the pre-flight again.
      </div>`;
    document.getElementById('analysisResults').classList.add('visible');
  }

  hideLoading();
}

function renderAnalysis(data, business, client) {
  const el = document.getElementById('analysisResults');
