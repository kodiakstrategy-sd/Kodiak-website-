<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kodiak — AI Assessment Tool</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black:  #080c12;
  --dark1:  #0d1117;
  --dark2:  #0f1923;
  --dark3:  #161f2e;
  --dark4:  #1c2a3d;
  --gold:   #b8952a;
  --gold2:  #d4aa45;
  --gold3:  #f0c96a;
  --goldDim: rgba(184,149,42,0.12);
  --white:  #ffffff;
  --off:    #e8e0d0;
  --gray:   #5a6478;
  --lgray:  #8a95a8;
  --border: rgba(184,149,42,0.15);
  --borderHover: rgba(184,149,42,0.4);
  --green:  #2a7a4b;
  --greenLight: #4ade80;
  --red:    #7a2a2a;
  --redLight: #f87171;
}

*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
background: var(–black);
color: var(–off);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
overflow-x: hidden;
}

/* Grain texture */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 512 512’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.75’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.04’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 0;
}

/* HEADER */
.app-header {
position: sticky;
top: 0;
z-index: 100;
background: rgba(8,12,18,0.95);
backdrop-filter: blur(20px);
border-bottom: 1px solid var(–border);
padding: 0 32px;
display: flex;
align-items: center;
justify-content: space-between;
height: 56px;
}

.header-brand {
display: flex;
align-items: center;
gap: 12px;
}

.brand-mark {
font-family: ‘DM Mono’, monospace;
font-size: 13px;
font-weight: 500;
letter-spacing: 0.3em;
color: var(–gold);
}

.brand-sep {
width: 1px;
height: 16px;
background: var(–border);
}

.brand-tool {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–lgray);
}

.header-status {
display: flex;
align-items: center;
gap: 8px;
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.1em;
color: var(–lgray);
}

.status-dot {
width: 6px;
height: 6px;
border-radius: 50%;
background: var(–greenLight);
box-shadow: 0 0 6px var(–greenLight);
}

/* MAIN LAYOUT */
.app-body {
display: grid;
grid-template-columns: 280px 1fr;
min-height: calc(100vh - 56px);
position: relative;
z-index: 1;
}

/* SIDEBAR */
.sidebar {
background: var(–dark1);
border-right: 1px solid var(–border);
padding: 28px 20px;
display: flex;
flex-direction: column;
gap: 4px;
}

.sidebar-section {
font-family: ‘DM Mono’, monospace;
font-size: 8px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–gray);
padding: 16px 12px 8px;
}

.step-btn {
display: flex;
align-items: center;
gap: 12px;
padding: 12px 14px;
border-radius: 6px;
border: none;
background: none;
cursor: pointer;
width: 100%;
text-align: left;
transition: all 0.2s;
position: relative;
}

.step-btn:hover { background: var(–goldDim); }
.step-btn.active { background: var(–goldDim); }
.step-btn.active::before {
content: ‘’;
position: absolute;
left: 0;
top: 4px;
bottom: 4px;
width: 2px;
background: var(–gold);
border-radius: 2px;
}

.step-num {
font-family: ‘Cormorant Garamond’, serif;
font-size: 22px;
font-weight: 300;
font-style: italic;
color: var(–gold);
opacity: 0.4;
width: 24px;
flex-shrink: 0;
transition: opacity 0.2s;
line-height: 1;
}
.step-btn.active .step-num,
.step-btn.done .step-num { opacity: 1; }

.step-info {}
.step-name {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–lgray);
display: block;
transition: color 0.2s;
}
.step-btn.active .step-name { color: var(–gold); }
.step-btn.done .step-name { color: var(–lgray); }

.step-desc {
font-size: 11px;
color: var(–gray);
display: block;
margin-top: 2px;
line-height: 1.4;
}

.step-check {
margin-left: auto;
color: var(–greenLight);
font-size: 14px;
opacity: 0;
transition: opacity 0.2s;
}
.step-btn.done .step-check { opacity: 1; }

/* MAIN CONTENT */
.main-content {
padding: 40px 48px;
max-width: 900px;
}

.step-panel { display: none; }
.step-panel.active { display: block; animation: fadeIn 0.3s ease; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* PANEL HEADER */
.panel-header {
margin-bottom: 32px;
}
.panel-eyebrow {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 10px;
}
.panel-title {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(28px, 3.5vw, 44px);
font-weight: 300;
line-height: 1.15;
color: var(–white);
margin-bottom: 10px;
}
.panel-title em { font-style: italic; color: var(–gold); }
.panel-sub {
font-size: 15px;
color: var(–lgray);
font-weight: 300;
line-height: 1.7;
max-width: 600px;
}

/* FORM ELEMENTS */
.form-section { margin-bottom: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.field-group { display: flex; flex-direction: column; gap: 6px; }
.field-label {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–lgray);
}
.field-required { color: var(–gold); margin-left: 2px; }

input, select, textarea {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 6px;
padding: 12px 16px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
color: var(–white);
outline: none;
transition: border-color 0.2s, background 0.2s;
width: 100%;
}
input::placeholder, textarea::placeholder { color: var(–gray); }
input:focus, select:focus, textarea:focus {
border-color: var(–gold);
background: var(–dark4);
}
select option { background: var(–dark2); }

.rates-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 12px;
}
.rate-card {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 8px;
padding: 14px;
transition: border-color 0.2s;
}
.rate-card:hover { border-color: var(–border); }
.rate-label {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–lgray);
margin-bottom: 8px;
}
.rate-input-wrap { display: flex; align-items: center; gap: 6px; }
.rate-symbol {
font-family: ‘DM Mono’, monospace;
font-size: 13px;
color: var(–gold);
}
.rate-input {
flex: 1;
padding: 8px 10px;
font-size: 15px;
font-weight: 500;
}

/* TRANSCRIPT */
.transcript-area {
background: var(–dark2);
border: 1px solid rgba(255,255,255,0.06);
border-radius: 10px;
padding: 20px;
margin-bottom: 16px;
}
.transcript-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 14px;
}
.transcript-label {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
}
.transcript-actions { display: flex; gap: 8px; }

textarea.transcript {
min-height: 280px;
font-family: ‘DM Mono’, monospace;
font-size: 12px;
line-height: 1.7;
resize: vertical;
background: transparent;
border: none;
padding: 0;
color: var(–lgray);
}
textarea.transcript:focus { border: none; background: transparent; }

.char-count {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gray);
text-align: right;
margin-top: 8px;
}

/* PREFLIGHT */
.preflight-results {
display: none;
background: var(–dark2);
border: 1px solid var(–border);
border-radius: 10px;
padding: 24px;
margin-bottom: 20px;
animation: fadeIn 0.3s ease;
}
.preflight-results.visible { display: block; }

.preflight-row {
display: flex;
align-items: center;
justify-content: space-between;
padding: 10px 0;
border-bottom: 1px solid rgba(255,255,255,0.04);
}
.preflight-row:last-child { border-bottom: none; }

.preflight-key {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.1em;
color: var(–lgray);
}
.preflight-val {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
font-weight: 500;
color: var(–white);
}
.preflight-val.good { color: var(–greenLight); }
.preflight-val.warn { color: var(–gold); }
.preflight-val.bad { color: var(–redLight); }

/* ANALYSIS RESULTS */
.analysis-section {
display: none;
animation: fadeIn 0.4s ease;
}
.analysis-section.visible { display: block; }

.roi-hero {
background: var(–dark2);
border: 1px solid var(–border);
border-top: 2px solid var(–gold);
border-radius: 10px;
padding: 28px;
margin-bottom: 24px;
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 24px;
}
.roi-stat {}
.roi-num {
font-family: ‘Cormorant Garamond’, serif;
font-size: 40px;
font-weight: 300;
color: var(–gold);
line-height: 1;
}
.roi-label {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–lgray);
margin-top: 6px;
}

.pillar-section { margin-bottom: 24px; }
.pillar-header {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 14px;
padding-bottom: 10px;
border-bottom: 1px solid rgba(255,255,255,0.04);
}
.pillar-icon { font-size: 18px; }
.pillar-name {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–gold);
}
.pillar-roi {
margin-left: auto;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–greenLight);
font-weight: 500;
}

.rec-card {
background: var(–dark3);
border: 1px solid rgba(255,255,255,0.04);
border-radius: 8px;
padding: 18px 20px;
margin-bottom: 10px;
transition: border-color 0.2s;
}
.rec-card:hover { border-color: var(–border); }
.rec-top {
display: flex;
align-items: flex-start;
justify-content: space-between;
gap: 12px;
margin-bottom: 8px;
}
.rec-pain {
font-size: 15px;
font-weight: 500;
color: var(–white);
line-height: 1.3;
}
.priority-badge {
font-family: ‘DM Mono’, monospace;
font-size: 8px;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 3px 8px;
border-radius: 3px;
flex-shrink: 0;
}
.priority-high { background: rgba(184,149,42,0.15); color: var(–gold); }
.priority-medium { background: rgba(138,149,168,0.15); color: var(–lgray); }
.priority-low { background: rgba(90,100,120,0.1); color: var(–gray); }

.rec-tool {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–gold);
margin-bottom: 6px;
}
.rec-desc { font-size: 13px; color: var(–lgray); line-height: 1.6; margin-bottom: 10px; }
.rec-metrics {
display: flex;
gap: 16px;
flex-wrap: wrap;
}
.rec-metric {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–gray);
letter-spacing: 0.04em;
}
.rec-metric strong { color: var(–greenLight); }

.qw-card {
background: var(–dark2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 16px 20px;
margin-bottom: 10px;
display: grid;
grid-template-columns: 48px 1fr;
gap: 16px;
align-items: start;
}
.qw-day {
font-family: ‘Cormorant Garamond’, serif;
font-size: 32px;
font-weight: 300;
font-style: italic;
color: var(–gold);
line-height: 1;
text-align: center;
}
.qw-content {}
.qw-tool { font-family: ‘DM Mono’, monospace; font-size: 11px; color: var(–gold); margin-bottom: 4px; }
.qw-task { font-size: 14px; font-weight: 500; color: var(–white); margin-bottom: 4px; }
.qw-time { font-family: ‘DM Mono’, monospace; font-size: 10px; color: var(–gray); }

/* BUTTONS */
.btn-primary {
background: var(–gold);
color: var(–black);
border: none;
border-radius: 6px;
padding: 13px 32px;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
font-weight: 500;
letter-spacing: 0.15em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
display: inline-flex;
align-items: center;
gap: 8px;
}
.btn-primary:hover { background: var(–gold2); transform: translateY(-1px); box-shadow: 0 6px 24px rgba(184,149,42,0.25); }
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

.btn-secondary {
background: var(–dark3);
color: var(–lgray);
border: 1px solid var(–border);
border-radius: 6px;
padding: 12px 24px;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 0.12em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}
.btn-secondary:hover { border-color: var(–gold); color: var(–gold); }

.btn-group { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }

/* LOADING */
.loading-overlay {
display: none;
position: fixed;
inset: 0;
background: rgba(8,12,18,0.85);
backdrop-filter: blur(8px);
z-index: 200;
align-items: center;
justify-content: center;
flex-direction: column;
gap: 24px;
}
.loading-overlay.visible { display: flex; }

.loading-ring {
width: 56px;
height: 56px;
border: 2px solid rgba(184,149,42,0.15);
border-top-color: var(–gold);
border-radius: 50%;
animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
}
.loading-sub {
font-size: 13px;
color: var(–lgray);
text-align: center;
max-width: 300px;
line-height: 1.6;
}

/* ERROR */
.error-box {
display: none;
background: rgba(122,42,42,0.15);
border: 1px solid rgba(248,113,113,0.2);
border-radius: 8px;
padding: 16px 20px;
margin-bottom: 20px;
font-size: 14px;
color: var(–redLight);
}
.error-box.visible { display: block; }

/* SCROLLBAR */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(–dark1); }
::-webkit-scrollbar-thumb { background: var(–dark4); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(–gold); }

@media(max-width: 768px) {
.app-body { grid-template-columns: 1fr; }
.sidebar { display: flex; flex-direction: row; overflow-x: auto; padding: 12px 16px; gap: 4px; border-right: none; border-bottom: 1px solid var(–border); }
.sidebar-section { display: none; }
.step-btn { min-width: 100px; }
.step-desc { display: none; }
.main-content { padding: 24px 20px; }
.form-row { grid-template-columns: 1fr; }
.rates-grid { grid-template-columns: 1fr 1fr; }
.roi-hero { grid-template-columns: 1fr; }
}
</style>

</head>
