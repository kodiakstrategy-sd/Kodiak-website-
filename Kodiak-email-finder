<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kodiak — Email Finder</title>
<style>
:root {
  --navy: #0d1526;
  --navy2: #111827;
  --navy3: #1a2236;
  --gold: #b8952a;
  --gold2: #d4aa45;
  --white: #ffffff;
  --gray: #6b7280;
  --lgray: #9ca3af;
  --border: rgba(184,149,42,0.2);
  --green: #10b981;
  --red: #dc2626;
  --blue: #0ea5e9;
}

- { box-sizing: border-box; margin: 0; padding: 0; }
  body {
  background: var(–navy);
  color: var(–white);
  font-family: ‘DM Sans’, -apple-system, sans-serif;
  min-height: 100vh;
  padding: 24px;
  }

/* HEADER */
.header {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 32px;
padding-bottom: 20px;
border-bottom: 1px solid var(–border);
}
.header-logo {
font-family: monospace;
font-size: 14px;
font-weight: 700;
letter-spacing: 0.3em;
color: var(–white);
}
.header-divider {
width: 1px;
height: 20px;
background: var(–border);
}
.header-title {
font-family: monospace;
font-size: 11px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
}

/* SEARCH FORM */
.search-card {
background: var(–navy2);
border: 1px solid var(–border);
border-radius: 12px;
padding: 28px;
margin-bottom: 24px;
}
.search-label {
font-family: monospace;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 16px;
display: block;
}
.search-row {
display: grid;
grid-template-columns: 1fr 200px 140px;
gap: 12px;
align-items: end;
}
.field-group { display: flex; flex-direction: column; gap: 6px; }
.field-label {
font-family: monospace;
font-size: 9px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–lgray);
}
input, select {
background: var(–navy3);
border: 1px solid rgba(255,255,255,0.08);
border-radius: 6px;
padding: 12px 16px;
font-size: 14px;
color: var(–white);
outline: none;
transition: border-color 0.2s;
width: 100%;
font-family: inherit;
}
input::placeholder { color: var(–gray); }
input:focus, select:focus { border-color: var(–gold); }
select option { background: var(–navy2); }

.search-btn {
background: var(–gold);
color: var(–navy);
border: none;
border-radius: 6px;
padding: 12px 20px;
font-family: monospace;
font-size: 11px;
font-weight: 700;
letter-spacing: 0.15em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
height: 44px;
white-space: nowrap;
}
.search-btn:hover { background: var(–gold2); transform: translateY(-1px); }
.search-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

/* BATCH MODE */
.batch-toggle {
display: flex;
align-items: center;
gap: 10px;
margin-top: 16px;
padding-top: 16px;
border-top: 1px solid rgba(255,255,255,0.05);
}
.batch-toggle label {
font-family: monospace;
font-size: 10px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–lgray);
cursor: pointer;
}
.toggle {
width: 36px;
height: 20px;
background: var(–navy3);
border: 1px solid var(–border);
border-radius: 10px;
cursor: pointer;
position: relative;
transition: background 0.2s;
flex-shrink: 0;
}
.toggle.on { background: var(–gold); border-color: var(–gold); }
.toggle::after {
content: ‘’;
position: absolute;
width: 14px;
height: 14px;
background: var(–white);
border-radius: 50%;
top: 2px;
left: 2px;
transition: transform 0.2s;
}
.toggle.on::after { transform: translateX(16px); }

.batch-area {
display: none;
margin-top: 16px;
}
.batch-area.visible { display: block; }
textarea {
width: 100%;
background: var(–navy3);
border: 1px solid rgba(255,255,255,0.08);
border-radius: 6px;
padding: 12px 16px;
font-size: 13px;
color: var(–white);
outline: none;
resize: vertical;
min-height: 120px;
font-family: monospace;
line-height: 1.6;
transition: border-color 0.2s;
}
textarea::placeholder { color: var(–gray); }
textarea:focus { border-color: var(–gold); }
.batch-hint {
font-family: monospace;
font-size: 10px;
color: var(–gray);
margin-top: 6px;
letter-spacing: 0.06em;
}

/* STATUS */
.status-bar {
display: none;
background: var(–navy2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 14px 20px;
margin-bottom: 20px;
align-items: center;
gap: 12px;
}
.status-bar.visible { display: flex; }
.status-spinner {
width: 16px;
height: 16px;
border: 2px solid rgba(184,149,42,0.2);
border-top-color: var(–gold);
border-radius: 50%;
animation: spin 0.8s linear infinite;
flex-shrink: 0;
}
.status-text {
font-family: monospace;
font-size: 11px;
letter-spacing: 0.08em;
color: var(–lgray);
}

/* RESULTS */
.results-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 16px;
}
.results-title {
font-family: monospace;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
}
.results-actions { display: flex; gap: 8px; }
.btn-sm {
background: var(–navy3);
color: var(–lgray);
border: 1px solid var(–border);
border-radius: 4px;
padding: 6px 14px;
font-family: monospace;
font-size: 9px;
letter-spacing: 0.1em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}
.btn-sm:hover { border-color: var(–gold); color: var(–gold); }

.result-card {
background: var(–navy2);
border: 1px solid var(–border);
border-radius: 10px;
padding: 20px 24px;
margin-bottom: 12px;
position: relative;
animation: fadeIn 0.3s ease;
}
.result-card.found { border-left: 3px solid var(–green); }
.result-card.partial { border-left: 3px solid var(–gold); }
.result-card.notfound { border-left: 3px solid var(–gray); }

.result-top {
display: flex;
align-items: flex-start;
justify-content: space-between;
gap: 16px;
margin-bottom: 12px;
}
.result-business {
font-size: 16px;
font-weight: 600;
color: var(–white);
}
.result-location {
font-family: monospace;
font-size: 10px;
letter-spacing: 0.08em;
color: var(–lgray);
margin-top: 3px;
}
.confidence-badge {
font-family: monospace;
font-size: 9px;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 3px;
flex-shrink: 0;
}
.confidence-high { background: rgba(16,185,129,0.15); color: var(–green); }
.confidence-med { background: rgba(184,149,42,0.15); color: var(–gold); }
.confidence-low { background: rgba(107,114,128,0.15); color: var(–lgray); }

.result-emails {
display: flex;
flex-direction: column;
gap: 8px;
margin-bottom: 12px;
}
.email-row {
display: flex;
align-items: center;
gap: 10px;
background: var(–navy3);
border-radius: 6px;
padding: 10px 14px;
}
.email-address {
font-family: monospace;
font-size: 13px;
color: var(–white);
flex: 1;
cursor: pointer;
transition: color 0.2s;
}
.email-address:hover { color: var(–gold); }
.email-type {
font-family: monospace;
font-size: 9px;
letter-spacing: 0.1em;
color: var(–lgray);
text-transform: uppercase;
}
.copy-btn {
background: none;
border: 1px solid var(–border);
border-radius: 3px;
padding: 3px 8px;
font-family: monospace;
font-size: 8px;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–lgray);
cursor: pointer;
transition: all 0.2s;
}
.copy-btn:hover { border-color: var(–gold); color: var(–gold); }
.copy-btn.copied { border-color: var(–green); color: var(–green); }

.result-meta {
display: flex;
gap: 16px;
flex-wrap: wrap;
}
.meta-item {
font-family: monospace;
font-size: 10px;
letter-spacing: 0.06em;
color: var(–gray);
}
.meta-item a { color: var(–blue); text-decoration: none; }
.meta-item a:hover { color: var(–gold); }

.result-note {
margin-top: 10px;
padding: 10px 14px;
background: rgba(184,149,42,0.05);
border-radius: 6px;
font-size: 12px;
color: var(–lgray);
line-height: 1.6;
}

.empty-state {
text-align: center;
padding: 60px 24px;
color: var(–gray);
}
.empty-icon { font-size: 40px; margin-bottom: 16px; opacity: 0.3; }
.empty-text { font-family: monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }

/* EXPORT */
.export-section {
display: none;
margin-top: 20px;
padding-top: 20px;
border-top: 1px solid var(–border);
}
.export-section.visible { display: block; }

@keyframes spin { to { transform: rotate(360deg); } }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

@media(max-width: 640px) {
.search-row { grid-template-columns: 1fr; }
body { padding: 16px; }
}
</style>

</head>
<body>

<div class="header">
  <span class="header-logo">KODIAK</span>
  <div class="header-divider"></div>
  <span class="header-title">Email Finder Agent</span>
</div>

<!-- SEARCH -->

<div class="search-card">
  <span class="search-label">Find contact email for a business</span>
  <div class="search-row">
    <div class="field-group">
      <span class="field-label">Business Name</span>
      <input type="text" id="businessName" placeholder="Haley Optical" />
    </div>
    <div class="field-group">
      <span class="field-label">City / State</span>
      <input type="text" id="location" placeholder="Rapid City, SD" />
    </div>
    <button class="search-btn" id="searchBtn" onclick="runSearch()">Find Email</button>
  </div>

  <!-- BATCH TOGGLE -->

  <div class="batch-toggle">
    <div class="toggle" id="batchToggle" onclick="toggleBatch()"></div>
    <label onclick="toggleBatch()">Batch mode — search multiple businesses at once</label>
  </div>

  <div class="batch-area" id="batchArea">
    <textarea id="batchInput" placeholder="One business per line:&#10;Haley Optical, Rapid City SD&#10;Black Hills HVAC, Rapid City SD&#10;Summit Dental, Spearfish SD"></textarea>
    <p class="batch-hint">Format: Business Name, City State — one per line. Max 10 per batch.</p>
    <div style="margin-top:12px;">
      <button class="search-btn" onclick="runBatch()">Find All Emails</button>
    </div>
  </div>
</div>

<!-- STATUS -->

<div class="status-bar" id="statusBar">
  <div class="status-spinner"></div>
  <span class="status-text" id="statusText">Searching the web for contact information...</span>
</div>

<!-- RESULTS -->

<div id="resultsSection" style="display:none;">
  <div class="results-header">
    <span class="results-title" id="resultsTitle">Results</span>
    <div class="results-actions">
      <button class="btn-sm" onclick="exportCSV()">Export CSV</button>
      <button class="btn-sm" onclick="clearResults()">Clear</button>
    </div>
  </div>
  <div id="resultsList"></div>

  <div class="export-section" id="exportSection">
    <button class="btn-sm" onclick="exportCSV()" style="width:100%;padding:12px;font-size:10px;">
      Download CSV — All Found Emails
    </button>
  </div>
</div>

<div class="empty-state" id="emptyState">
  <div class="empty-icon">🔍</div>
  <div class="empty-text">Enter a business name to find their contact email</div>
</div>

<script>
let allResults = [];
let batchMode = false;

function toggleBatch() {
  batchMode = !batchMode;
  document.getElementById('batchToggle').classList.toggle('on', batchMode);
  document.getElementById('batchArea').classList.toggle('visible', batchMode);
}

function setStatus(text, show = true) {
  const bar = document.getElementById('statusBar');
  document.getElementById('statusText').textContent = text;
  bar.classList.toggle('visible', show);
}

async function callClaude(prompt) {
  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      tools: [{ type: 'web_search_20250305', name: 'web_search' }],
      messages: [{ role: 'user', content: prompt }]
    })
  });
  const data = await response.json();
  const text = data.content
    .filter(b => b.type === 'text')
    .map(b => b.text)
    .join('');
  return text;
}

function buildPrompt(business, location) {
  return `Find the contact email address for this business: "${business}" located in "${location}".

Search their website, Google Business Profile, LinkedIn, and any other public sources.

Return your findings as JSON only — no explanation, no markdown, exactly this format:
{
  "business": "${business}",
  "location": "${location}",
  "website": "url or null",
  "emails": [
    {"address": "email@domain.com", "type": "general/owner/sales/info/contact", "confidence": "high/medium/low"}
  ],
  "phone": "phone number or null",
  "found": true/false,
  "note": "one sentence about the source or any relevant info"
}

If no email is found set found to false and emails to an empty array. Return JSON only.`;
}

async function runSearch() {
  const business = document.getElementById('businessName').value.trim();
  const location = document.getElementById('location').value.trim();

  if (!business) {
    document.getElementById('businessName').focus();
    return;
  }

  const btn = document.getElementById('searchBtn');
  btn.disabled = true;
  setStatus(`Searching for ${business}...`);
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('resultsSection').style.display = 'block';

  try {
    const raw = await callClaude(buildPrompt(business, location));
    const clean = raw.replace(/```json|```/g, '').trim();
    const result = JSON.parse(clean);
    allResults.unshift(result);
    renderResults();
  } catch (err) {
    allResults.unshift({
      business,
      location,
      found: false,
      emails: [],
      website: null,
      phone: null,
      note: 'Search encountered an error — try again or search manually.'
    });
    renderResults();
  }

  setStatus('', false);
  btn.disabled = false;
}

async function runBatch() {
  const lines = document.getElementById('batchInput').value
    .split('\n')
    .map(l => l.trim())
    .filter(l => l.length > 0)
    .slice(0, 10);

  if (lines.length === 0) return;

  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('resultsSection').style.display = 'block';

  for (let i = 0; i < lines.length; i++) {
    const parts = lines[i].split(',');
    const business = parts[0]?.trim() || lines[i];
    const location = parts.slice(1).join(',').trim() || '';

    setStatus(`Searching ${i + 1} of ${lines.length}: ${business}...`);

    try {
      const raw = await callClaude(buildPrompt(business, location));
      const clean = raw.replace(/```json|```/g, '').trim();
      const result = JSON.parse(clean);
      allResults.push(result);
    } catch {
      allResults.push({
        business, location, found: false, emails: [],
        website: null, phone: null, note: 'Search error — try individually.'
      });
    }
    renderResults();
    await new Promise(r => setTimeout(r, 800));
  }

  setStatus('', false);
  if (allResults.length > 1) {
    document.getElementById('exportSection').classList.add('visible');
  }
}

function renderResults() {
  const list = document.getElementById('resultsList');
  const title = document.getElementById('resultsTitle');
  const found = allResults.filter(r => r.found).length;
  title.textContent = `Results — ${allResults.length} searched, ${found} found`;

  list.innerHTML = allResults.map((r, i) => {
    const statusClass = r.found ? 'found' : r.emails?.length ? 'partial' : 'notfound';
    const conf = r.emails?.[0]?.confidence || 'low';
    const confClass = conf === 'high' ? 'confidence-high' : conf === 'medium' ? 'confidence-med' : 'confidence-low';
    const confLabel = conf === 'high' ? 'High Confidence' : conf === 'medium' ? 'Medium' : 'Low Confidence';

    const emailsHTML = r.emails?.length ? r.emails.map(e => `
      <div class="email-row">
        <span class="email-address" onclick="copyEmail('${e.address}', this)">${e.address}</span>
        <span class="email-type">${e.type || ''}</span>
        <button class="copy-btn" onclick="copyEmail('${e.address}', this)">Copy</button>
      </div>
    `).join('') : `<div style="font-family:monospace;font-size:11px;color:var(--gray);padding:8px 0;">No email found — manual search required</div>`;

    return `
      <div class="result-card ${statusClass}">
        <div class="result-top">
          <div>
            <div class="result-business">${r.business}</div>
            <div class="result-location">${r.location || '—'}</div>
          </div>
          ${r.found ? `<span class="confidence-badge ${confClass}">${confLabel}</span>` : '<span class="confidence-badge confidence-low">Not Found</span>'}
        </div>
        <div class="result-emails">${emailsHTML}</div>
        <div class="result-meta">
          ${r.website ? `<span class="meta-item">🌐 <a href="${r.website}" target="_blank">${r.website}</a></span>` : ''}
          ${r.phone ? `<span class="meta-item">📞 ${r.phone}</span>` : ''}
        </div>
        ${r.note ? `<div class="result-note">${r.note}</div>` : ''}
      </div>
    `;
  }).join('');
}

function copyEmail(email, btn) {
  navigator.clipboard.writeText(email).then(() => {
    if (btn.classList.contains('copy-btn')) {
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 2000);
    }
  });
}

function exportCSV() {
  const rows = [['Business', 'Location', 'Email', 'Type', 'Confidence', 'Website', 'Phone', 'Notes']];
  allResults.forEach(r => {
    if (r.emails?.length) {
      r.emails.forEach(e => {
        rows.push([r.business, r.location, e.address, e.type, e.confidence, r.website || '', r.phone || '', r.note || '']);
      });
    } else {
      rows.push([r.business, r.location, '', '', '', r.website || '', r.phone || '', r.note || '']);
    }
  });
  const csv = rows.map(r => r.map(c => `"${(c||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `kodiak-leads-${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
}

function clearResults() {
  allResults = [];
  document.getElementById('resultsList').innerHTML = '';
  document.getElementById('resultsSection').style.display = 'none';
  document.getElementById('emptyState').style.display = 'block';
  document.getElementById('exportSection').classList.remove('visible');
}

document.getElementById('businessName').addEventListener('keypress', e => {
  if (e.key === 'Enter') runSearch();
});
</script>

</body>
</html>
