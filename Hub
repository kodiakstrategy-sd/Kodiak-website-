<title>Kodiak Hub</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { background: #0B0B0B; }
body { background: #0B0B0B; color: #FFFFFF; font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif; min-height: 100vh; overflow-x: hidden; }
body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events: none; z-index: 0; }

/* LOGIN */
.login-screen { position: fixed; inset: 0; background: #0B0B0B; display: flex; align-items: center; justify-content: center; z-index: 100; padding: 24px; }
.login-card { width: 100%; max-width: 380px; background: #111111; border: 1px solid rgba(198,168,90,0.2); border-top: 2px solid #C6A85A; border-radius: 4px; padding: 40px 36px; }
.login-logo { font-size: 22px; font-weight: 900; letter-spacing: 0.3em; color: #FFFFFF; text-transform: uppercase; text-align: center; margin-bottom: 4px; }
.login-rule { width: 40px; height: 1px; background: #C6A85A; margin: 10px auto; }
.login-sub { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: #C6A85A; text-align: center; margin-bottom: 32px; }
.login-label { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #666666; display: block; margin-bottom: 8px; }
.login-input { width: 100%; background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 2px; padding: 13px 16px; font-size: 16px; color: #FFFFFF; outline: none; transition: border-color 0.2s; letter-spacing: 0.1em; text-align: center; font-family: ‘Courier New’, monospace; }
.login-input:focus { border-color: #C6A85A; }
.login-btn { width: 100%; background: #C6A85A; color: #0B0B0B; border: none; border-radius: 2px; padding: 13px; font-family: ‘Courier New’, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; margin-top: 12px; transition: all 0.2s; }
.login-btn:hover { background: #E0C97A; }
.login-error { font-family: ‘Courier New’, monospace; font-size: 10px; color: #f87171; text-align: center; margin-top: 12px; letter-spacing: 0.08em; display: none; }
.login-error.visible { display: block; }

/* HUB */
.hub-screen { display: none; position: relative; z-index: 1; }
.hub-screen.visible { display: block; }

.hub-header { position: sticky; top: 0; z-index: 100; background: rgba(11,11,11,0.96); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(198,168,90,0.15); padding: 0 28px; display: flex; align-items: center; justify-content: space-between; height: 56px; }
.header-brand { display: flex; align-items: center; gap: 10px; }
.brand-mark { font-family: ‘Courier New’, monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.3em; color: #C6A85A; }
.brand-sep { width: 1px; height: 16px; background: rgba(198,168,90,0.2); }
.brand-tool { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #666666; }
.logout-btn { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.1em; color: #444444; background: none; border: none; cursor: pointer; transition: color 0.2s; }
.logout-btn:hover { color: #f87171; }

.hub-body { padding: 32px 28px; max-width: 1100px; margin: 0 auto; }

/* GREETING */
.greeting { margin-bottom: 32px; }
.greeting-time { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: #444444; margin-bottom: 6px; }
.greeting-text { font-size: 22px; font-weight: 700; color: #FFFFFF; text-transform: uppercase; letter-spacing: -0.01em; }
.greeting-text span { color: #C6A85A; }

/* STATUS */
.status-strip { background: #111111; border: 1px solid rgba(198,168,90,0.1); border-radius: 4px; padding: 16px 24px; display: flex; align-items: center; gap: 28px; margin-bottom: 32px; flex-wrap: wrap; }
.status-item { display: flex; align-items: center; gap: 8px; }
.status-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.dot-green { background: #4ade80; box-shadow: 0 0 6px #4ade80; }
.dot-gold { background: #C6A85A; box-shadow: 0 0 6px #C6A85A; }
.dot-gray { background: #444444; }
.status-text { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.06em; color: #666666; }
.status-text strong { color: #FFFFFF; }

/* TOOLS */
.section-label { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: #C6A85A; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
.section-label::after { content: ‘’; flex: 1; height: 1px; background: rgba(198,168,90,0.15); }
.tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; margin-bottom: 40px; }
.tool-card { background: #111111; border: 1px solid rgba(198,168,90,0.12); border-radius: 4px; padding: 28px 24px; text-decoration: none; display: flex; flex-direction: column; position: relative; overflow: hidden; transition: all 0.25s; }
.tool-card::before { content: ‘’; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: #C6A85A; transform: scaleX(0); transition: transform 0.3s ease; transform-origin: left; }
.tool-card:hover { background: #161616; border-color: rgba(198,168,90,0.3); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.4); }
.tool-card:hover::before { transform: scaleX(1); }
.tool-icon { font-size: 28px; margin-bottom: 16px; }
.tool-num { font-family: ‘Courier New’, monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; color: #444444; margin-bottom: 6px; }
.tool-name { font-size: 17px; font-weight: 700; color: #FFFFFF; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 8px; line-height: 1.2; }
.tool-name span { color: #C6A85A; }
.tool-desc { font-size: 13px; color: #666666; line-height: 1.7; font-weight: 300; flex: 1; margin-bottom: 20px; }
.tool-arrow { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: #C6A85A; display: flex; align-items: center; gap: 8px; transition: gap 0.2s; }
.tool-card:hover .tool-arrow { gap: 12px; }

/* QUICK LINKS */
.links-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-bottom: 40px; }
.quick-link { background: #0d1117; border: 1px solid rgba(255,255,255,0.04); border-radius: 4px; padding: 14px 18px; text-decoration: none; display: flex; align-items: center; gap: 12px; transition: all 0.2s; }
.quick-link:hover { background: rgba(198,168,90,0.06); border-color: rgba(198,168,90,0.2); transform: translateY(-2px); }
.ql-icon { font-size: 16px; flex-shrink: 0; }
.ql-name { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #999999; display: block; }
.ql-desc { font-size: 11px; color: #444444; display: block; margin-top: 2px; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

@media(max-width: 768px) {
.hub-header { padding: 0 16px; }
.hub-body { padding: 20px 16px; }
.status-strip { gap: 16px; }
.tools-grid { grid-template-columns: 1fr; }
.links-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

