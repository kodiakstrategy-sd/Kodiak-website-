<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kodiak — Content Intelligence Agent</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { background: #0B0B0B; scroll-behavior: smooth; }
body { background: #0B0B0B; color: #FFFFFF; font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif; line-height: 1.7; min-height: 100vh; overflow-x: hidden; }

body::before { content: ‘’; position: fixed; inset: 0; background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 512 512’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.75’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.03’/%3E%3C/svg%3E”); pointer-events: none; z-index: 0; }

.app-header { position: sticky; top: 0; z-index: 100; background: rgba(11,11,11,0.96); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(198,168,90,0.15); padding: 0 28px; display: flex; align-items: center; justify-content: space-between; height: 56px; }
.header-left { display: flex; align-items: center; gap: 12px; }
.brand-mark { font-family: ‘Courier New’, monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.3em; color: #C6A85A; }
.brand-sep { width: 1px; height: 16px; background: rgba(198,168,90,0.2); }
.brand-tool { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #666666; }
.header-back { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.1em; color: #666666; text-decoration: none; }
.header-back:hover { color: #C6A85A; }

.main { padding: 32px 28px; max-width: 960px; margin: 0 auto; position: relative; z-index: 1; }

/* CONTROL PANEL */
.control-panel { background: #111111; border: 1px solid rgba(198,168,90,0.15); border-top: 2px solid #C6A85A; border-radius: 4px; padding: 28px; margin-bottom: 24px; }
.control-title { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: #C6A85A; margin-bottom: 20px; }
.control-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.control-group { display: flex; flex-direction: column; gap: 6px; }
.control-label { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: #666666; }
select, input { background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 2px; padding: 10px 14px; font-family: -apple-system, sans-serif; font-size: 13px; color: #FFFFFF; outline: none; transition: border-color 0.2s; width: 100%; }
select:focus, input:focus { border-color: #C6A85A; }
select option { background: #1A1A1A; }

.run-btn { background: #C6A85A; color: #0B0B0B; border: none; border-radius: 2px; padding: 13px 32px; font-family: ‘Courier New’, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; gap: 10px; }
.run-btn:hover { background: #E0C97A; transform: translateY(-1px); }
.run-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

/* LOADING */
.loading-bar { display: none; background: #111111; border: 1px solid rgba(198,168,90,0.15); border-radius: 4px; padding: 24px 28px; margin-bottom: 24px; }
.loading-bar.visible { display: block; }
.loading-phase { font-family: ‘Courier New’, monospace; font-size: 11px; letter-spacing: 0.1em; color: #C6A85A; margin-bottom: 8px; }
.loading-sub { font-size: 12px; color: #666666; }
.progress-track { height: 2px; background: #1A1A1A; border-radius: 1px; margin-top: 14px; overflow: hidden; }
.progress-fill { height: 100%; background: #C6A85A; border-radius: 1px; transition: width 0.5s ease; width: 0%; }

/* SYNOPSIS */
.synopsis-card { background: #111111; border: 1px solid rgba(198,168,90,0.2); border-top: 2px solid #C6A85A; border-radius: 4px; padding: 28px; margin-bottom: 24px; display: none; }
.synopsis-card.visible { display: block; animation: fadeIn 0.4s ease; }
.synopsis-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.synopsis-title { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: #C6A85A; }
.synopsis-date { font-family: ‘Courier New’, monospace; font-size: 9px; color: #444444; letter-spacing: 0.08em; }
.synopsis-body { font-size: 15px; color: #999999; line-height: 1.8; font-weight: 300; }
.synopsis-body strong { color: #FFFFFF; font-weight: 600; }
.synopsis-body em { color: #C6A85A; font-style: normal; font-weight: 500; }

/* TRENDS GRID */
.trends-section { margin-bottom: 24px; display: none; }
.trends-section.visible { display: block; animation: fadeIn 0.4s ease; }
.section-label { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: #C6A85A; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
.section-label::after { content: ‘’; flex: 1; height: 1px; background: rgba(198,168,90,0.15); }
.trends-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.trend-card { background: #111111; border: 1px solid rgba(255,255,255,0.04); border-radius: 4px; padding: 20px; transition: border-color 0.2s; }
.trend-card:hover { border-color: rgba(198,168,90,0.2); }
.trend-platform { font-family: ‘Courier New’, monospace; font-size: 8px; letter-spacing: 0.15em; text-transform: uppercase; color: #C6A85A; margin-bottom: 8px; }
.trend-hook { font-size: 14px; font-weight: 600; color: #FFFFFF; margin-bottom: 8px; line-height: 1.3; }
.trend-why { font-size: 12px; color: #666666; line-height: 1.6; }
.trend-metric { font-family: ‘Courier New’, monospace; font-size: 10px; color: #C6A85A; margin-top: 10px; }

/* POSTS SECTION */
.posts-section { display: none; }
.posts-section.visible { display: block; animation: fadeIn 0.4s ease; }
.post-card { background: #111111; border: 1px solid rgba(198,168,90,0.15); border-radius: 4px; margin-bottom: 16px; overflow: hidden; }
.post-header { background: #1A1A1A; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.04); }
.post-meta { display: flex; align-items: center; gap: 12px; }
.post-num { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.15em; color: #444444; }
.post-type { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 10px; border-radius: 2px; }
.type-hook { background: rgba(198,168,90,0.12); color: #C6A85A; }
.type-pain { background: rgba(248,113,113,0.1); color: #f87171; }
.type-roi { background: rgba(74,222,128,0.1); color: #4ade80; }
.type-authority { background: rgba(96,165,250,0.1); color: #60a5fa; }
.post-actions { display: flex; gap: 8px; }
.copy-btn { background: #2A2A2A; border: 1px solid rgba(198,168,90,0.15); border-radius: 2px; padding: 6px 14px; font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #666666; cursor: pointer; transition: all 0.2s; }
.copy-btn:hover { border-color: #C6A85A; color: #C6A85A; }
.copy-btn.copied { border-color: #4ade80; color: #4ade80; }
.post-body { padding: 24px; }
.post-image-prompt { background: #0B0B0B; border: 1px solid rgba(198,168,90,0.1); border-radius: 2px; padding: 12px 16px; margin-bottom: 16px; font-size: 12px; color: #666666; font-family: ‘Courier New’, monospace; line-height: 1.6; }
.post-image-prompt::before { content: ’IMAGE: ’; color: #C6A85A; font-weight: 700; }
.post-caption { font-size: 14px; color: #CCCCCC; line-height: 1.85; white-space: pre-wrap; }
.post-hashtags { margin-top: 12px; font-size: 12px; color: #444444; font-family: ‘Courier New’, monospace; }
.post-why { margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.04); font-size: 12px; color: #555555; line-height: 1.6; font-style: italic; }
.post-why::before { content: ’WHY THIS WORKS: ’; color: #C6A85A; font-style: normal; font-weight: 700; font-size: 9px; letter-spacing: 0.1em; }

/* EMPTY STATE */
.empty-state { text-align: center; padding: 80px 24px; color: #333333; }
.empty-icon { font-size: 48px; opacity: 0.2; margin-bottom: 16px; }
.empty-text { font-family: ‘Courier New’, monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
@keyframes spin { to { transform: rotate(360deg); } }

@media(max-width: 768px) {
.main { padding: 20px 16px; }
.control-row { grid-template-columns: 1fr; }
.trends-grid { grid-template-columns: 1fr; }
.app-header { padding: 0 16px; }
}
</style>

</head>
<body>

<header class="app-header">
  <div class="header-left">
    <span class="brand-mark">KODIAK</span>
    <div class="brand-sep"></div>
    <span class="brand-tool">Content Intelligence</span>
  </div>
  <a href="kodiak-command-center.html" class="header-back">← Command Center</a>
</header>

<div class="main">

  <!-- CONTROL PANEL -->

  <div class="control-panel">
    <div class="control-title">Weekly Content Brief — Configure & Run</div>
    <div class="control-row">
      <div class="control-group">
        <label class="control-label">Industry Focus</label>
        <select id="industry">
          <option value="AI consulting small business">AI Consulting — Small Business</option>
          <option value="business automation">Business Automation</option>
          <option value="AI for contractors">AI for Contractors</option>
          <option value="AI for medical practices">AI for Medical Practices</option>
          <option value="small business South Dakota">Small Business — South Dakota</option>
        </select>
      </div>
      <div class="control-group">
        <label class="control-label">Content Pillars</label>
        <select id="pillar">
          <option value="all pillars">All Pillars — Rotate</option>
          <option value="pain points">Pain Points</option>
          <option value="ROI and results">ROI & Results</option>
          <option value="quick wins and tools">Quick Wins & Tools</option>
          <option value="authority and education">Authority & Education</option>
        </select>
      </div>
      <div class="control-group">
        <label class="control-label">Posts This Week</label>
        <select id="postCount">
          <option value="3">3 posts</option>
          <option value="4" selected>4 posts</option>
          <option value="5">5 posts</option>
          <option value="7">7 posts — daily</option>
        </select>
      </div>
    </div>
    <div class="control-row">
      <div class="control-group">
        <label class="control-label">Accounts to Research</label>
        <input type="text" id="competitors" placeholder="e.g. Corey Ganim, Alex Hormozi, Gary Vee" value="Corey Ganim, Alex Hormozi, Neil Patel, Justin Welsh" />
      </div>
      <div class="control-group">
        <label class="control-label">Keywords to Track</label>
        <input type="text" id="keywords" placeholder="AI consulting, business automation, small business AI" value="AI consulting, business automation, AI for small business" />
      </div>
      <div class="control-group">
        <label class="control-label">Target Audience</label>
        <select id="audience">
          <option value="small business owners in South Dakota">SD Small Business Owners</option>
          <option value="contractors and trades businesses">Contractors & Trades</option>
          <option value="medical and dental practice owners">Medical & Dental Practices</option>
          <option value="general small business owners">General Small Business</option>
        </select>
      </div>
    </div>
    <button class="run-btn" id="runBtn" onclick="runAgent()">
      <span id="runBtnText">Run Weekly Brief</span>
    </button>
  </div>

  <!-- LOADING -->

  <div class="loading-bar" id="loadingBar">
    <div class="loading-phase" id="loadingPhase">Scanning trending content...</div>
    <div class="loading-sub" id="loadingSub">Researching top performing hooks and formats in your industry</div>
    <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
  </div>

  <!-- SYNOPSIS -->

  <div class="synopsis-card" id="synopsisCard">
    <div class="synopsis-header">
      <span class="synopsis-title">What's Working This Week — Synopsis</span>
      <span class="synopsis-date" id="synopsisDate"></span>
    </div>
    <div class="synopsis-body" id="synopsisBody"></div>
  </div>

  <!-- TRENDS -->

  <div class="trends-section" id="trendsSection">
    <div class="section-label">Top Performing Hooks & Formats</div>
    <div class="trends-grid" id="trendsGrid"></div>
  </div>

  <!-- POSTS -->

  <div class="posts-section" id="postsSection">
    <div class="section-label">Your Posts This Week — Ready to Copy</div>
    <div id="postsList"></div>
  </div>

  <!-- EMPTY STATE -->

  <div class="empty-state" id="emptyState">
    <div class="empty-icon">📡</div>
    <div class="empty-text">Configure and run your weekly brief above</div>
  </div>

</div>

<script>
const VOICE_SOP = `
KODIAK STRATEGY CONTENT VOICE — STRICT RULES:

Write like talking to a business owner at a job site. Direct. Slightly blunt. Conversational.
Short sentences. Imperfect is fine. No buzzwords. No AI language.

Write this: "You're on a job. Call goes to voicemail. They've moved on."
NOT this: "Businesses often experience delayed response times."

NEVER say: leverage, synergy, cutting-edge, innovative, solutions, game-changer, AI-powered, disrupting, In today's fast-paced world

CAPTION STRUCTURE:
1. Hook — stops the scroll, one line, makes them read the next
2. Call out false assumption
3. Make it real — job site, missed call, invoice, front desk
4. Simple explanation of what's actually happening
5. "We fix that." — one line
6. Soft CTA — "Book an Assessment — kodiakstrategy.com"

IMAGE TEXT: 5-8 words max. One idea. No CTA.

ALWAYS end with: Book an Assessment
NEVER: Book an Audit

Brand: Kodiak Strategy. Black Hills, SD. AI consulting for owner-operated businesses.
Target: Small business owners in South Dakota — contractors, medical practices, law firms, service businesses.
`;

async function callClaude(prompt, systemPrompt = '') {
  const body = {
    model: 'claude-sonnet-4-20250514',
    max_tokens: 1000,
    tools: [{ type: 'web_search_20250305', name: 'web_search' }],
    messages: [{ role: 'user', content: prompt }]
  };
  if (systemPrompt) body.system = systemPrompt;
  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  const data = await response.json();
  return data.content.filter(b => b.type === 'text').map(b => b.text).join('');
}

function parseJSON(text) {
  const clean = text.replace(/```json|```/g, '').trim();
  const start = clean.indexOf('{') !== -1 ? clean.indexOf('{') : clean.indexOf('[');
  const end = clean.lastIndexOf('}') !== -1 ? clean.lastIndexOf('}') : clean.lastIndexOf(']');
  if (start === -1 || end === -1) throw new Error('No JSON');
  return JSON.parse(clean.slice(start, end + 1));
}

function setLoading(phase, sub, progress) {
  document.getElementById('loadingPhase').textContent = phase;
  document.getElementById('loadingSub').textContent = sub;
  document.getElementById('progressFill').style.width = progress + '%';
}

async function runAgent() {
  const industry = document.getElementById('industry').value;
  const pillar = document.getElementById('pillar').value;
  const postCount = parseInt(document.getElementById('postCount').value);
  const competitors = document.getElementById('competitors').value;
  const keywords = document.getElementById('keywords').value;
  const audience = document.getElementById('audience').value;

  const btn = document.getElementById('runBtn');
  btn.disabled = true;
  document.getElementById('runBtnText').textContent = 'Running...';
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('loadingBar').classList.add('visible');
  document.getElementById('synopsisCard').classList.remove('visible');
  document.getElementById('trendsSection').classList.remove('visible');
  document.getElementById('postsSection').classList.remove('visible');

  try {
    // PHASE 1 — Research trending content
    setLoading('Scanning trending content...', `Researching what is performing in ${industry} right now`, 15);

    const researchRaw = await callClaude(`
Search for the most engaging and high-performing social media content in these areas RIGHT NOW:
- Industry: ${industry}
- Keywords: ${keywords}
- Accounts to research: ${competitors}
- Platforms: Instagram, Facebook, X/Twitter, TikTok

Find what hooks, formats, and content types are getting the most engagement.

Return JSON only:
{
  "synopsis": "3-4 sentence plain-English summary of what is working right now and why — written for a non-expert business owner",
  "whatIsWorking": "2-3 specific patterns or formats getting high engagement",
  "whatIsNot": "1-2 things that used to work but are declining",
  "topHooks": [
    {
      "platform": "Instagram/Facebook/X/TikTok",
      "hook": "the actual opening line or hook",
      "why": "one sentence on why it works",
      "engagement": "high/very high/viral"
    }
  ],
  "formatsTrending": ["format1", "format2", "format3"],
  "keyInsight": "the single most important thing to know about content this week"
}
    `);

    setLoading('Analyzing patterns...', 'Identifying what resonates with your specific audience', 45);
    const research = parseJSON(researchRaw);

    // PHASE 2 — Generate posts
    setLoading('Writing your posts...', `Drafting ${postCount} Kodiak-branded posts ready to publish`, 70);

    const postsRaw = await callClaude(`
You are a content strategist for Kodiak Strategy — a premium AI consulting firm in the Black Hills of South Dakota.

Using these trending insights from ${industry} content:
- What's working: ${research.whatIsWorking}
- Top hooks: ${JSON.stringify(research.topHooks?.slice(0,3))}
- Key insight: ${research.keyInsight}
- Target audience: ${audience}
- Content focus: ${pillar}

Write ${postCount} complete social media posts for Kodiak Strategy.

Return JSON only:
{
  "posts": [
    {
      "postNumber": 1,
      "type": "pain_point OR roi OR hook OR authority",
      "imageText": "5-8 words for the image — one idea only",
      "imagePrompt": "describe the visual for this post in one sentence",
      "caption": "full caption following Kodiak voice — short punchy lines, real scenarios, ends with Book an Assessment",
      "hashtags": "#tag1 #tag2 #tag3 #tag4 #tag5",
      "whyItWorks": "one sentence on why this post will perform based on current trends"
    }
  ]
}
    `, VOICE_SOP);

    setLoading('Finalizing brief...', 'Packaging your weekly content intelligence report', 90);
    const postsData = parseJSON(postsRaw);

    // Render everything
    renderSynopsis(research);
    renderTrends(research);
    renderPosts(postsData.posts || []);

    document.getElementById('loadingBar').classList.remove('visible');
    setLoading('', '', 0);

  } catch (err) {
    document.getElementById('loadingPhase').textContent = 'Error — ' + err.message;
    document.getElementById('loadingSub').textContent = 'Check connection and try again';
  }

  btn.disabled = false;
  document.getElementById('runBtnText').textContent = 'Run Weekly Brief';
}

function renderSynopsis(data) {
  const card = document.getElementById('synopsisCard');
  document.getElementById('synopsisDate').textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });

  document.getElementById('synopsisBody').innerHTML = `
    <p style="margin-bottom:16px;">${data.synopsis || ''}</p>
    ${data.whatIsWorking ? `<p style="margin-bottom:8px;"><strong>What's working:</strong> ${data.whatIsWorking}</p>` : ''}
    ${data.whatIsNot ? `<p style="margin-bottom:8px;"><strong>What's fading:</strong> ${data.whatIsNot}</p>` : ''}
    ${data.keyInsight ? `<p style="margin-top:16px;padding:14px 20px;background:#1A1A1A;border-left:2px solid #C6A85A;font-size:14px;"><em>${data.keyInsight}</em></p>` : ''}
  `;
  card.classList.add('visible');
}

function renderTrends(data) {
  const hooks = data.topHooks || [];
  if (!hooks.length) return;

  document.getElementById('trendsGrid').innerHTML = hooks.map(h => `
    <div class="trend-card">
      <div class="trend-platform">${h.platform || 'Social'}</div>
      <div class="trend-hook">"${h.hook}"</div>
      <div class="trend-why">${h.why || ''}</div>
      <div class="trend-metric">${h.engagement || 'High'} engagement</div>
    </div>
  `).join('');

  document.getElementById('trendsSection').classList.add('visible');
}

function renderPosts(posts) {
  if (!posts.length) return;

  const typeMap = {
    'pain_point': ['PAIN POINT', 'type-pain'],
    'roi': ['ROI', 'type-roi'],
    'hook': ['HOOK', 'type-hook'],
    'authority': ['AUTHORITY', 'type-authority'],
  };

  document.getElementById('postsList').innerHTML = posts.map((post, i) => {
    const [typeLabel, typeCls] = typeMap[post.type] || ['POST', 'type-hook'];
    const fullText = `${post.imageText ? 'IMAGE: ' + post.imageText + '\n\n' : ''}${post.caption || ''}\n\n${post.hashtags || ''}`.trim();

    return `
      <div class="post-card">
        <div class="post-header">
          <div class="post-meta">
            <span class="post-num">POST ${i + 1}</span>
            <span class="post-type ${typeCls}">${typeLabel}</span>
          </div>
          <div class="post-actions">
            <button class="copy-btn" onclick="copyPost(this, \`${fullText.replace(/`/g, '\\`')}\`)">Copy</button>
          </div>
        </div>
        <div class="post-body">
          ${post.imageText ? `<div class="post-image-prompt">${post.imageText}</div>` : ''}
          ${post.imagePrompt ? `<div style="font-family:'Courier New',monospace;font-size:10px;color:#444;margin-bottom:12px;padding:8px 12px;background:#0B0B0B;border-radius:2px;">VISUAL: ${post.imagePrompt}</div>` : ''}
          <div class="post-caption">${(post.caption || '').replace(/\n/g, '<br>')}</div>
          ${post.hashtags ? `<div class="post-hashtags">${post.hashtags}</div>` : ''}
          ${post.whyItWorks ? `<div class="post-why">${post.whyItWorks}</div>` : ''}
        </div>
      </div>
    `;
  }).join('');

  document.getElementById('postsSection').classList.add('visible');
}

function copyPost(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 2000);
  });
}
</script>

</body>
