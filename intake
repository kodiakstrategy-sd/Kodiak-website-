<body>
<div class="vignette"></div>
<nav class="nav">
  <a href="/" class="nav-brand"><img src="/D3A18687-A4A5-4047-832C-6A78DB334E01.jpeg" alt="Kodiak" class="nav-logo"><span class="nav-wordmark">Kodiak <em>Strategy</em></span></a>
  <a href="tel:9075004010" class="nav-phone">(907) 500-4010</a>
</nav>
<div class="page">
  <div class="intake-grid">

    <div class="intake-left">
      <div class="kicker">Get Started</div>
      <h1>Start the <strong>conversation.</strong></h1>
      <p class="lead">Tell us a little about your business. Ryan will follow up personally to set up your free discovery call. Twenty minutes, no pitch, no pressure. Just a real conversation about your operation and whether there's something worth building.</p>

      <div class="contact-card">
        <div class="cc-label">Call or text directly</div>
        <div class="cc-body"><a href="tel:9075004010">(907) 500-4010</a></div>
        <div class="cc-sub">Ryan Fagerstrom · Founder</div>
      </div>
      <div class="contact-card">
        <div class="cc-label">Email</div>
        <div class="cc-body"><a href="mailto:ryan@kodiakstrategy.com">ryan@kodiakstrategy.com</a></div>
      </div>
      <p class="calendly-line">Prefer to schedule online? <a href="https://calendly.com/kodiakstrategysd" target="_blank" rel="noopener">Book on Calendly &rarr;</a></p>
    </div>

    <div class="intake-right">
      <h2>Tell us about your business.</h2>
      <p class="form-sub">We'll be in touch shortly.</p>
      <form id="intake-form" action="https://services.leadconnectorhq.com/hooks/JxQ9amINRIrgtoArjsAs/webhook-trigger/45e10fae-e8b3-4036-b35a-bedadbbf0216" method="POST">
        <div class="form-row">
          <div class="field-group"><label>Your Name</label><input type="text" name="name" placeholder="First Last" required></div>
          <div class="field-group"><label>Business Name</label><input type="text" name="business" placeholder="Acme Roofing Co." required></div>
        </div>
        <div class="field-group">
          <label>Industry</label>
          <select name="industry" required>
            <option value="" disabled selected>Select your industry</option>
            <option>Optometry / Eye Care</option>
            <option>Dental Practice</option>
            <option>Medical / Healthcare</option>
            <option>Law Firm</option>
            <option>Accounting / Bookkeeping</option>
            <option>Insurance Agency</option>
            <option>Roofing / Construction</option>
            <option>HVAC / Home Services</option>
            <option>Real Estate</option>
            <option>Restaurant / Hospitality</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-row">
          <div class="field-group"><label>Email Address</label><input type="email" name="email" placeholder="you@yourbusiness.com" required></div>
          <div class="field-group"><label>Phone Number</label><input type="tel" name="phone" placeholder="(000) 000-0000" required></div>
        </div>
        <div class="field-group">
          <label>Biggest operational challenge right now</label>
          <textarea name="challenge" placeholder="What takes the most time, or causes the most friction, in your business?" required></textarea>
        </div>
        <div class="opt-in">
          <input type="checkbox" id="sms_opt_in" name="sms_opt_in" value="yes">
          <label class="opt-in-label" for="sms_opt_in">I'd like to receive text updates from Kodiak Strategy about my discovery call and next steps. Message and data rates may apply. Reply STOP to opt out. <a href="/privacy">Privacy Policy</a></label>
        </div>
        <button type="submit" class="submit-btn">Request My Discovery Call</button>
        <p class="form-note">Your information is never shared with third parties.</p>
      </form>
    </div>

  </div>
</div>
<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">Kodiak <em>Strategy</em></div>
    <div class="footer-links">
      <a href="/" class="footer-link">Home</a>
      <a href="/how-it-works" class="footer-link">How It Works</a>
      <a href="/services" class="footer-link">Services</a>
      <a href="/about" class="footer-link">About</a>
      <a href="/faq" class="footer-link">FAQ</a>
      <a href="/privacy" class="footer-link">Privacy</a>
    </div>
  </div>
  <div class="footer-contact">(907) 500-4010 &nbsp;·&nbsp; ryan@kodiakstrategy.com &nbsp;·&nbsp; Black Hills, South Dakota</div>
</footer>
<script>
document.getElementById('intake-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = this;
  const btn = form.querySelector('.submit-btn');
  btn.disabled = true;
  btn.textContent = 'Sending...';
  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    });
    if (res.ok) {
      btn.textContent = 'Received — Ryan will be in touch shortly.';
    } else {
      btn.textContent = 'Something went wrong — call (907) 500-4010';
      btn.disabled = false;
    }
  } catch (err) {
    btn.textContent = 'Something went wrong — call (907) 500-4010';
    btn.disabled = false;
  }
});
</script>
</body>
</html>
