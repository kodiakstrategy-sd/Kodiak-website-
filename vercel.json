{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.kodiakstrategy.com" }],
      "destination": "https://kodiakstrategy.com/:path*",
      "permanent": true
    },
    {
      "source": "/Home",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/((?!.*\\..*$).*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ]
}
