<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kodiak — Knowledge Base</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { background: #0B0B0B; scroll-behavior: smooth; }
body { background: #0B0B0B; color: #FFFFFF; font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif; line-height: 1.7; min-height: 100vh; overflow-x: hidden; }
body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events: none; z-index: 0; }

.app-header { position: sticky; top: 0; z-index: 100; background: rgba(11,11,11,0.96); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(198,168,90,0.15); padding: 0 28px; display: flex; align-items: center; justify-content: space-between; height: 56px; }
.header-left { display: flex; align-items: center; gap: 12px; }
.brand-mark { font-family: ‘Courier New’, monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.3em; color: #C6A85A; }
.brand-sep { width: 1px; height: 16px; background: rgba(198,168,90,0.2); }
.brand-tool { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #666666; }
.header-right { display: flex; align-items: center; gap: 12px; }
.header-back { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.1em; color: #666666; text-decoration: none; }
.header-back:hover { color: #C6A85A; }
.add-btn { background: #C6A85A; color: #0B0B0B; border: none; border-radius: 2px; padding: 8px 20px; font-family: ‘Courier New’, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.add-btn:hover { background: #E0C97A; }

.app-body { display: grid; grid-template-columns: 260px 1fr; min-height: calc(100vh - 56px); position: relative; z-index: 1; }

/* SIDEBAR */
.sidebar { background: #0d1117; border-right: 1px solid rgba(198,168,90,0.1); padding: 20px 16px; display: flex; flex-direction: column; gap: 2px; position: sticky; top: 56px; height: calc(100vh - 56px); overflow-y: auto; }
.sidebar-label { font-family: ‘Courier New’, monospace; font-size: 8px; letter-spacing: 0.25em; text-transform: uppercase; color: #333333; padding: 12px 12px 6px; }
.cat-btn { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-radius: 2px; border: none; background: none; cursor: pointer; width: 100%; text-align: left; transition: background 0.2s; }
.cat-btn:hover { background: rgba(198,168,90,0.06); }
.cat-btn.active { background: rgba(198,168,90,0.1); }
.cat-name { font-family: ‘Courier New’, monospace; font-size: 10px; letter-spacing: 0.1em; color: #999999; transition: color 0.2s; }
.cat-btn.active .cat-name, .cat-btn:hover .cat-name { color: #C6A85A; }
.cat-count { font-family: ‘Courier New’, monospace; font-size: 9px; color: #333333; background: #1A1A1A; padding: 2px 7px; border-radius: 10px; }

/* MAIN */
.main { padding: 28px; overflow-y: auto; }

/* TOOLBAR */
.toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
.search-wrap { position: relative; flex: 1; min-width: 200px; }
.search-input { width: 100%; background: #111111; border: 1px solid rgba(255,255,255,0.06); border-radius: 2px; padding: 10px 14px 10px 36px; font-size: 13px; color: #FFFFFF; outline: none; transition: border-color 0.2s; font-family: inherit; }
.search-input:focus { border-color: #C6A85A; }
.search-input::placeholder { color: #444444; }
.search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #444444; font-size: 13px; }
.filter-select { background: #111111; border: 1px solid rgba(255,255,255,0.06); border-radius: 2px; padding: 10px 14px; font-family: ‘Courier New’, monospace; font-size: 10px; color: #999999; outline: none; cursor: pointer; transition: border-color 0.2s; }
.filter-select:focus { border-color: #C6A85A; }
.filter-select option { background: #111111; }
.entry-count { font-family: ‘Courier New’, monospace; font-size: 10px; color: #444444; margin-left: auto; letter-spacing: 0.08em; }

/* ENTRIES */
.entry-card { background: #111111; border: 1px solid rgba(255,255,255,0.04); border-radius: 4px; padding: 20px 24px; margin-bottom: 12px; transition: border-color 0.2s; animation: fadeIn 0.2s ease; cursor: pointer; }
.entry-card:hover { border-color: rgba(198,168,90,0.2); }
.entry-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
.entry-title { font-size: 15px; font-weight: 600; color: #FFFFFF; line-height: 1.3; }
.entry-meta { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.entry-cat { font-family: ‘Courier New’, monospace; font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 9px; border-radius: 2px; white-space: nowrap; }
.cat-framework { background: rgba(198,168,90,0.12); color: #C6A85A; }
.cat-tool { background: rgba(96,165,250,0.1); color: #60a5fa; }
.cat-competitor { background: rgba(167,139,250,0.1); color: #a78bfa; }
.cat-content { background: rgba(74,222,128,0.1); color: #4ade80; }
.cat-strategy { background: rgba(251,191,36,0.1); color: #fbbf24; }
.cat-industry { background: rgba(248,113,113,0.1); color: #f87171; }
.cat-research { background: rgba(156,163,175,0.1); color: #9ca3af; }
.entry-date { font-family: ‘Courier New’, monospace; font-size: 9px; color: #333333; }
.entry-summary { font-size: 13px; color: #999999; line-height: 1.7; margin-bottom: 10px; font-weight: 300; }
.entry-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.entry-tag { font-family: ‘Courier New’, monospace; font-size: 9px; color: #444444; background: #1A1A1A; padding: 3px 8px; border-radius: 2px; }
.entry-actions { display: flex; gap: 6px; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.03); }
.action-btn { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; padding: 5px 12px; border-radius: 2px; background: #1A1A1A; border: 1px solid rgba(255,255,255,0.04); color: #666666; cursor: pointer; transition: all 0.2s; }
.action-btn:hover { border-color: #C6A85A; color: #C6A85A; }
.action-btn.danger:hover { border-color: #f87171; color: #f87171; }

/* MODAL */
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(11,11,11,0.9); backdrop-filter: blur(12px); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
.modal-overlay.visible { display: flex; }
.modal { background: #111111; border: 1px solid rgba(198,168,90,0.2); border-top: 2px solid #C6A85A; border-radius: 4px; padding: 32px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; animation: modalIn 0.25s ease; }
@keyframes modalIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.modal-title { font-size: 20px; font-weight: 700; color: #FFFFFF; text-transform: uppercase; letter-spacing: -0.01em; }
.modal-title span { color: #C6A85A; }
.modal-close { background: none; border: none; color: #444444; font-size: 20px; cursor: pointer; transition: color 0.2s; }
.modal-close:hover { color: #FFFFFF; }
.form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.form-label { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: #666666; }
input, select, textarea { background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 2px; padding: 11px 14px; font-family: -apple-system, sans-serif; font-size: 14px; color: #FFFFFF; outline: none; transition: border-color 0.2s; width: 100%; }
input:focus, select:focus, textarea:focus { border-color: #C6A85A; }
input::placeholder, textarea::placeholder { color: #444444; }
select option { background: #1A1A1A; }
textarea { resize: vertical; min-height: 100px; line-height: 1.6; }
.modal-actions { display: flex; gap: 10px; margin-top: 8px; }
.save-btn { flex: 1; background: #C6A85A; color: #0B0B0B; border: none; border-radius: 2px; padding: 12px; font-family: ‘Courier New’, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.save-btn:hover { background: #E0C97A; }
.cancel-btn { background: #1A1A1A; color: #666666; border: 1px solid rgba(198,168,90,0.15); border-radius: 2px; padding: 12px 20px; font-family: ‘Courier New’, monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.cancel-btn:hover { border-color: #C6A85A; color: #C6A85A; }

/* STATS BAR */
.stats-bar { display: flex; gap: 24px; margin-bottom: 24px; flex-wrap: wrap; }
.stat { background: #111111; border: 1px solid rgba(198,168,90,0.1); border-radius: 4px; padding: 16px 20px; }
.stat-num { font-size: 28px; font-weight: 800; color: #C6A85A; line-height: 1; }
.stat-label { font-family: ‘Courier New’, monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: #444444; margin-top: 4px; }

/* EMPTY */
.empty-state { text-align: center; padding: 60px 24px; }
.empty-icon { font-size: 40px; opacity: 0.2; margin-bottom: 16px; }
.empty-text { font-family: ‘Courier New’, monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #333333; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

@media(max-width: 768px) {
.app-body { grid-template-columns: 1fr; }
.sidebar { position: static; height: auto; display: flex; flex-direction: row; overflow-x: auto; padding: 10px 16px; border-right: none; border-bottom: 1px solid rgba(198,168,90,0.1); gap: 4px; }
.sidebar-label { display: none; }
.cat-btn { min-width: 100px; }
.main { padding: 16px; }
}
</style>

</head>
<body>

<!-- ADD MODAL -->

<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Add <span>Entry</span></div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <input type="hidden" id="editId" />
    <div class="form-group">
      <label class="form-label">Title *</label>
      <input type="text" id="f_title" placeholder="e.g. Job-to-be-done framework — outcome thinking" />
    </div>
    <div class="form-group">
      <label class="form-label">Category *</label>
      <select id="f_category">
        <option value="framework">Framework — Mental Models & Approaches</option>
        <option value="tool">Tool — Software & Products</option>
        <option value="competitor">Competitor — What Others Are Doing</option>
        <option value="content">Content — Hooks, Formats & Strategies</option>
        <option value="strategy">Strategy — Business & Sales Tactics</option>
        <option value="industry">Industry — Vertical-Specific Insights</option>
        <option value="research">Research — Studies, Data & Sources</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Summary *</label>
      <textarea id="f_summary" placeholder="What is this? Why does it matter to Kodiak? What did you learn?"></textarea>
    </div>
    <div class="form-group">
      <label class="form-label">Source / URL</label>
      <input type="text" id="f_source" placeholder="URL, book, podcast, person, etc." />
    </div>
    <div class="form-group">
      <label class="form-label">How it applies to Kodiak</label>
      <textarea id="f_application" placeholder="How does this change how we operate, sell, or deliver?" style="min-height:80px;"></textarea>
    </div>
    <div class="form-group">
      <label class="form-label">Tags (comma separated)</label>
      <input type="text" id="f_tags" placeholder="e.g. frameworks, sales, AI, content" />
    </div>
    <div class="modal-actions">
      <button class="cancel-btn" onclick="closeModal()">Cancel</button>
      <button class="save-btn" onclick="saveEntry()">Save Entry →</button>
    </div>
  </div>
</div>

<!-- HEADER -->

<header class="app-header">
  <div class="header-left">
    <span class="brand-mark">KODIAK</span>
    <div class="brand-sep"></div>
    <span class="brand-tool">Knowledge Base</span>
  </div>
  <div class="header-right">
    <a href="kodiak-command-center.html" class="header-back">← Command Center</a>
    <button class="add-btn" onclick="openModal()">+ Add Entry</button>
  </div>
</header>

<div class="app-body">

  <!-- SIDEBAR -->

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-label">Categories</div>
    <button class="cat-btn active" data-cat="all" onclick="filterCat('all', this)">
      <span class="cat-name">All Entries</span>
      <span class="cat-count" id="count-all">0</span>
    </button>
    <button class="cat-btn" data-cat="framework" onclick="filterCat('framework', this)">
      <span class="cat-name">Frameworks</span>
      <span class="cat-count" id="count-framework">0</span>
    </button>
    <button class="cat-btn" data-cat="tool" onclick="filterCat('tool', this)">
      <span class="cat-name">Tools</span>
      <span class="cat-count" id="count-tool">0</span>
    </button>
    <button class="cat-btn" data-cat="competitor" onclick="filterCat('competitor', this)">
      <span class="cat-name">Competitors</span>
      <span class="cat-count" id="count-competitor">0</span>
    </button>
    <button class="cat-btn" data-cat="content" onclick="filterCat('content', this)">
      <span class="cat-name">Content</span>
      <span class="cat-count" id="count-content">0</span>
    </button>
    <button class="cat-btn" data-cat="strategy" onclick="filterCat('strategy', this)">
      <span class="cat-name">Strategy</span>
      <span class="cat-count" id="count-strategy">0</span>
    </button>
    <button class="cat-btn" data-cat="industry" onclick="filterCat('industry', this)">
      <span class="cat-name">Industry</span>
      <span class="cat-count" id="count-industry">0</span>
    </button>
    <button class="cat-btn" data-cat="research" onclick="filterCat('research', this)">
      <span class="cat-name">Research</span>
      <span class="cat-count" id="count-research">0</span>
    </button>
  </aside>

  <!-- MAIN -->

  <main class="main">
    <div class="stats-bar" id="statsBar"></div>
    <div class="toolbar">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text" class="search-input" id="searchInput" placeholder="Search knowledge base..." oninput="render()" />
      </div>
      <select class="filter-select" id="sortSelect" onchange="render()">
        <option value="recent">Most Recent</option>
        <option value="az">A to Z</option>
        <option value="cat">By Category</option>
      </select>
      <span class="entry-count" id="entryCount">0 entries</span>
    </div>
    <div id="entriesList"></div>
    <div class="empty-state" id="emptyState">
      <div class="empty-icon">🧠</div>
      <div class="empty-text">Your knowledge base is empty — add your first entry</div>
    </div>
  </main>
</div>

<script>
let entries = JSON.parse(localStorage.getItem('kodiak_knowledge') || '[]');
let activeCategory = 'all';

const CAT_CLASSES = {
  framework: 'cat-framework', tool: 'cat-tool', competitor: 'cat-competitor',
  content: 'cat-content', strategy: 'cat-strategy', industry: 'cat-industry', research: 'cat-research'
};
const CAT_LABELS = {
  framework: 'Framework', tool: 'Tool', competitor: 'Competitor',
  content: 'Content', strategy: 'Strategy', industry: 'Industry', research: 'Research'
};

function save() { localStorage.setItem('kodiak_knowledge', JSON.stringify(entries)); }
function genId() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }

function openModal(id = null) {
  const isEdit = !!id;
  document.getElementById('editId').value = id || '';
  if (isEdit) {
    const e = entries.find(x => x.id === id);
    if (!e) return;
    document.getElementById('f_title').value = e.title || '';
    document.getElementById('f_category').value = e.category || 'framework';
    document.getElementById('f_summary').value = e.summary || '';
    document.getElementById('f_source').value = e.source || '';
    document.getElementById('f_application').value = e.application || '';
    document.getElementById('f_tags').value = (e.tags || []).join(', ');
  } else {
    ['f_title','f_summary','f_source','f_application','f_tags'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('f_category').value = 'framework';
  }
  document.getElementById('modalOverlay').classList.add('visible');
  setTimeout(() => document.getElementById('f_title').focus(), 100);
}

function closeModal() { document.getElementById('modalOverlay').classList.remove('visible'); }

function saveEntry() {
  const title = document.getElementById('f_title').value.trim();
  if (!title) { document.getElementById('f_title').focus(); return; }
  const editId = document.getElementById('editId').value;
  const data = {
    title,
    category: document.getElementById('f_category').value,
    summary: document.getElementById('f_summary').value,
    source: document.getElementById('f_source').value,
    application: document.getElementById('f_application').value,
    tags: document.getElementById('f_tags').value.split(',').map(t => t.trim()).filter(Boolean),
    updatedAt: Date.now()
  };
  if (editId) {
    const idx = entries.findIndex(e => e.id === editId);
    if (idx > -1) entries[idx] = { ...entries[idx], ...data };
  } else {
    entries.unshift({ id: genId(), ...data, createdAt: Date.now() });
  }
  save(); render(); updateCounts(); closeModal();
}

function deleteEntry(id) {
  if (!confirm('Delete this entry?')) return;
  entries = entries.filter(e => e.id !== id);
  save(); render(); updateCounts();
}

function filterCat(cat, btn) {
  activeCategory = cat;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function updateCounts() {
  const cats = ['all','framework','tool','competitor','content','strategy','industry','research'];
  cats.forEach(cat => {
    const count = cat === 'all' ? entries.length : entries.filter(e => e.category === cat).length;
    const el = document.getElementById('count-' + cat);
    if (el) el.textContent = count;
  });

  // Stats bar
  document.getElementById('statsBar').innerHTML = `
    <div class="stat"><div class="stat-num">${entries.length}</div><div class="stat-label">Total Entries</div></div>
    <div class="stat"><div class="stat-num">${entries.filter(e=>e.category==='framework').length}</div><div class="stat-label">Frameworks</div></div>
    <div class="stat"><div class="stat-num">${entries.filter(e=>e.category==='tool').length}</div><div class="stat-label">Tools</div></div>
    <div class="stat"><div class="stat-num">${entries.filter(e=>e.category==='competitor').length}</div><div class="stat-label">Competitors</div></div>
  `;
}

function render() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const sort = document.getElementById('sortSelect').value;

  let filtered = entries.filter(e => {
    const matchCat = activeCategory === 'all' || e.category === activeCategory;
    const matchSearch = !search || (e.title + e.summary + e.application + (e.tags||[]).join(' ')).toLowerCase().includes(search);
    return matchCat && matchSearch;
  });

  if (sort === 'az') filtered.sort((a,b) => a.title.localeCompare(b.title));
  else if (sort === 'cat') filtered.sort((a,b) => a.category.localeCompare(b.category));
  else filtered.sort((a,b) => b.createdAt - a.createdAt);

  document.getElementById('entryCount').textContent = `${filtered.length} entr${filtered.length !== 1 ? 'ies' : 'y'}`;
  const list = document.getElementById('entriesList');
  const empty = document.getElementById('emptyState');

  if (!filtered.length) {
    list.innerHTML = '';
    empty.style.display = entries.length ? 'none' : 'block';
    if (entries.length && !filtered.length) list.innerHTML = `<div style="text-align:center;padding:40px;font-family:'Courier New',monospace;font-size:11px;color:#333;">No entries match your search</div>`;
    return;
  }
  empty.style.display = 'none';

  list.innerHTML = filtered.map(e => `
    <div class="entry-card">
      <div class="entry-top">
        <div class="entry-title">${e.title}</div>
        <div class="entry-meta">
          <span class="entry-cat ${CAT_CLASSES[e.category] || ''}">${CAT_LABELS[e.category] || e.category}</span>
          <span class="entry-date">${new Date(e.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric'})}</span>
        </div>
      </div>
      ${e.summary ? `<div class="entry-summary">${e.summary}</div>` : ''}
      ${e.application ? `<div style="font-size:12px;color:#555;line-height:1.6;margin-bottom:10px;padding:10px 14px;background:#0B0B0B;border-left:2px solid #C6A85A;"><span style="font-family:'Courier New',monospace;font-size:9px;color:#C6A85A;font-weight:700;letter-spacing:0.1em;">KODIAK APPLICATION: </span>${e.application}</div>` : ''}
      ${e.source ? `<div style="font-family:'Courier New',monospace;font-size:10px;color:#444;margin-bottom:8px;">SOURCE: ${e.source}</div>` : ''}
      ${e.tags?.length ? `<div class="entry-tags">${e.tags.map(t=>`<span class="entry-tag">${t}</span>`).join('')}</div>` : ''}
      <div class="entry-actions">
        <button class="action-btn" onclick="openModal('${e.id}')">Edit</button>
        <button class="action-btn danger" onclick="deleteEntry('${e.id}')">Delete</button>
      </div>
    </div>
  `).join('');
}

// Seed with today's key entries
if (entries.length === 0) {
  const seed = [
    { id: genId(), title: 'Job-to-be-done → Outcome Framework', category: 'framework', summary: 'Stop asking what the job is. Ask what outcome they are trying to reach. Everyone else automates the job. We rethink the process and work backward from the desired outcome. A body shop chasing insurance approvals needs approvals to happen automatically — not a faster way to chase them.', source: 'Internal — Ryan Fagerstrom / Session May 2026', application: 'Reframes every assessment. The five outcome questions are now standard in every interview. Changes how we write reports and position recommendations.', tags: ['frameworks','assessment','positioning','core'], createdAt: Date.now() },
