</div>

<!-- TOOLBAR -->

<div class="toolbar">
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" class="search-input" id="searchInput" placeholder="Search leads..." oninput="renderTable()" />
  </div>
  <select class="filter-select" id="filterStatus" onchange="renderTable()">
    <option value="">All Statuses</option>
    <option>New</option>
    <option>Contacted</option>
    <option>Follow-Up</option>
    <option>Warm</option>
    <option>Call Booked</option>
    <option>Assessment Scheduled</option>
    <option>Report Out</option>
    <option>Strategy Call</option>
    <option>Proposal Sent</option>
    <option>Negotiating</option>
    <option>Closed Won</option>
    <option>Closed Lost</option>
  </select>
  <select class="filter-select" id="filterIndustry" onchange="renderTable()">
    <option value="">All Industries</option>
    <option>Optometry / Eye Care</option>
    <option>Dental Practice</option>
    <option>Medical / Healthcare</option>
    <option>Law Firm</option>
    <option>Roofing / Construction</option>
    <option>HVAC / Home Services</option>
    <option>Real Estate</option>
