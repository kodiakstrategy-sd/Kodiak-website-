      <div class="header-stat-label">Total</div>
    </div>
    <div class="header-stat">
      <div class="header-stat-num" id="statActive">0</div>
      <div class="header-stat-label">Active</div>
    </div>
    <div class="header-stat">
      <div class="header-stat-num" id="statOverdue">0</div>
      <div class="header-stat-label">Overdue</div>
    </div>
