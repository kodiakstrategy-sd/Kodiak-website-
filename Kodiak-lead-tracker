  <div class="drawer-section">
    <div class="drawer-section-label">Activity Log</div>
    <div id="d_activity">—</div>
  </div>

  <div class="drawer-actions">
    <div class="drawer-btn primary" onclick="editFromDrawer()">Edit Lead</div>
    <div class="drawer-btn" onclick="markFollowedUp()">Mark Followed Up</div>
    <div class="drawer-btn" style="color:var(--red);border-color:rgba(248,113,113,0.2);" onclick="deleteLead()">Delete</div>
  </div>
</div>

<!-- APP -->

<header class="app-header">
  <div class="header-left">
    <span class="brand-mark">KODIAK</span>
    <div class="brand-sep"></div>
