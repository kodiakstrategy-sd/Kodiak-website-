  <span class="toolbar-count" id="toolbarCount">0 leads</span>
</div>

<!-- TABLE -->

<div class="table-wrap">
  <table class="lead-table">
    <thead>
      <tr>
        <th>Contact / Business</th>
        <th>Status</th>
        <th>Industry</th>
        <th>Follow-Up</th>
        <th>Value</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="leadTableBody"></tbody>
  </table>
  <div class="empty-state" id="emptyState">
    <div class="empty-icon">📋</div>
    <div class="empty-text">No leads yet — add your first one</div>
    <button class="btn-add" onclick="openModal()">+ Add Lead</button>
  </div>
</div>

<script>
// ── SUPABASE CONFIG ──
const SUPABASE_URL = 'https://flhnntxmikmppcoucdky.supabase.co';
const getKey = () => localStorage.getItem('kodiak_supabase_key') || '';

async function sbFetch(path, method = 'GET', body = null) {
  const key = getKey();
  const opts = {
    method,
    headers: {
      'apikey': key,
      'Authorization': `Bearer ${key}`,
      'Content-Type': 'application/json',
      'Prefer': method === 'POST' ? 'resolution=merge-duplicates' : ''
    }
  };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, opts);
  if (method === 'GET' && res.ok) return res.json();
  return res;
}

// ── DATA ──
let leads = [];
let activeDrawerId = null;
const STAGES = ['New','Contacted','Follow-Up','Warm','Call Booked','Assessment Scheduled','Report Out','Strategy Call','Proposal Sent','Negotiating','Closed Won','Closed Lost'];
const STATUS_CLASS = {
  'New':'s-new','Contacted':'s-contacted','Follow-Up':'s-followup','Warm':'s-warm',
  'Call Booked':'s-callbooked','Assessment Scheduled':'s-assessment','Report Out':'s-reportout',
  'Strategy Call':'s-strategycall','Proposal Sent':'s-proposal','Negotiating':'s-negotiating',
  'Closed Won':'s-closed','Closed Lost':'s-lost'
};

async function loadLeads() {
  if (!getKey()) {
    // Fallback to localStorage if no key
    leads = JSON.parse(localStorage.getItem('kodiak_leads') || '[]');
    return;
  }
  try {
    const data = await sbFetch('leads?order=created_at.desc');
    leads = data.map(l => ({
      id: l.id, name: l.name, business: l.business,
      industry: l.industry, city: l.city, phone: l.phone,
      email: l.email, status: l.status, dealValue: l.deal_value,
      source: l.source, followUpDate: l.follow_up_date,
      notes: l.notes, activity: l.activity || [],
      createdAt: l.created_at
    }));
  } catch(e) {
    leads = JSON.parse(localStorage.getItem('kodiak_leads') || '[]');
  }
}

async function save() {
  if (!getKey()) { localStorage.setItem('kodiak_leads', JSON.stringify(leads)); return; }
  // Push all leads to Supabase
  const mapped = leads.map(l => ({
    id: l.id, name: l.name, business: l.business,
    industry: l.industry, city: l.city, phone: l.phone,
    email: l.email, status: l.status, deal_value: l.dealValue,
    source: l.source, follow_up_date: l.followUpDate,
    notes: l.notes, activity: l.activity || [],
    created_at: l.createdAt
  }));
  await sbFetch('leads', 'POST', mapped);
  localStorage.setItem('kodiak_leads', JSON.stringify(leads));
}

function genId() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }

// ── PIPELINE STRIP ──
function renderPipeline() {
  const strip = document.getElementById('pipelineStrip');
  const counts = {};
  STAGES.forEach(s => counts[s] = 0);
  leads.forEach(l => { if (counts[l.status] !== undefined) counts[l.status]++; });

  strip.innerHTML = STAGES.map(s => `
    <div class="pipeline-stage" onclick="filterByStage('${s}')">
      <div class="stage-count">${counts[s]}</div>
      <div class="stage-name">${s}</div>
    </div>`).join('');
}

function filterByStage(stage) {
  document.getElementById('filterStatus').value = stage;
  renderTable();
}

// ── STATS ──
function renderStats() {
  const active = leads.filter(l => l.status !== 'Closed Won' && l.status !== 'Closed Lost').length;
  const today = new Date().toDateString();
  const overdue = leads.filter(l => {
    if (!l.followUpDate) return false;
    return new Date(l.followUpDate) < new Date() && l.status !== 'Closed Won' && l.status !== 'Closed Lost';
  }).length;
  const pipeline = leads.reduce((sum, l) => sum + (parseFloat(l.dealValue) || 0), 0);

  document.getElementById('statTotal').textContent = leads.length;
  document.getElementById('statActive').textContent = active;
  document.getElementById('statOverdue').textContent = overdue;
  document.getElementById('statPipeline').textContent = '$' + pipeline.toLocaleString();
}

// ── TABLE ──
function getFilteredLeads() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const status = document.getElementById('filterStatus').value;
  const industry = document.getElementById('filterIndustry').value;
  const sort = document.getElementById('filterSort').value;

  let filtered = leads.filter(l => {
    const matchSearch = !search ||
      l.name?.toLowerCase().includes(search) ||
      l.business?.toLowerCase().includes(search) ||
      l.city?.toLowerCase().includes(search) ||
      l.email?.toLowerCase().includes(search);
    const matchStatus = !status || l.status === status;
    const matchIndustry = !industry || l.industry === industry;
    return matchSearch && matchStatus && matchIndustry;
  });

  if (sort === 'followup') filtered.sort((a, b) => new Date(a.followUpDate || '9999') - new Date(b.followUpDate || '9999'));
  else if (sort === 'value') filtered.sort((a, b) => (b.dealValue || 0) - (a.dealValue || 0));
  else if (sort === 'name') filtered.sort((a, b) => a.name?.localeCompare(b.name || '') || 0);
  else filtered.sort((a, b) => b.createdAt - a.createdAt);

  return filtered;
}

function formatFollowUp(dateStr) {
  if (!dateStr) return { text: '—', cls: '' };
  const date = new Date(dateStr);
  const today = new Date();
  today.setHours(0,0,0,0);
  date.setHours(0,0,0,0);
  const diff = Math.round((date - today) / 86400000);

  if (diff < 0) return { text: `${Math.abs(diff)}d overdue`, cls: 'overdue' };
  if (diff === 0) return { text: 'Today', cls: 'today' };
  if (diff === 1) return { text: 'Tomorrow', cls: 'today' };
  if (diff <= 7) return { text: `In ${diff} days`, cls: 'upcoming' };
  return { text: date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }), cls: 'upcoming' };
}

function renderTable() {
  const filtered = getFilteredLeads();
  const tbody = document.getElementById('leadTableBody');
  const empty = document.getElementById('emptyState');

  document.getElementById('toolbarCount').textContent = `${filtered.length} lead${filtered.length !== 1 ? 's' : ''}`;

  if (!filtered.length) {
    tbody.innerHTML = '';
    empty.style.display = leads.length ? 'none' : 'block';
    if (leads.length) {
      tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:40px;font-family:'DM Mono',monospace;font-size:11px;color:var(--gray);">No leads match your filters</td></tr>`;
    }
    return;
  }

  empty.style.display = 'none';
  const fu = filtered.map(l => formatFollowUp(l.followUpDate));

  tbody.innerHTML = filtered.map((l, i) => `
    <tr class="lead-row" onclick="openDrawer('${l.id}')">
      <td>
        <span class="lead-name">${l.name || '—'}</span>
        <span class="lead-biz">${l.business || ''}</span>
      </td>
      <td><span class="status-pill ${STATUS_CLASS[l.status] || 's-new'}">${l.status || 'New'}</span></td>
      <td style="font-size:12px;color:var(--lgray);">${l.industry || '—'}</td>
      <td><span class="follow-up-date ${fu[i].cls}">${fu[i].text}</span></td>
      <td><span class="deal-value">${l.dealValue ? '$' + parseFloat(l.dealValue).toLocaleString() : '—'}</span></td>
      <td onclick="event.stopPropagation()">
        <div class="action-btns">
          <button class="action-btn" onclick="openEditModal('${l.id}')">Edit</button>
          <button class="action-btn danger" onclick="confirmDelete('${l.id}')">✕</button>
        </div>
      </td>
    </tr>`).join('');

  renderPipeline();
  renderStats();
}

// ── MODAL ──
function openModal(id = null) {
  const isEdit = !!id;
  document.getElementById('modalTitle').innerHTML = isEdit ? 'Edit <em>Lead</em>' : 'Add <em>New Lead</em>';
  document.getElementById('editId').value = id || '';

  if (isEdit) {
    const l = leads.find(x => x.id === id);
    if (!l) return;
    document.getElementById('f_name').value = l.name || '';
    document.getElementById('f_business').value = l.business || '';
    document.getElementById('f_industry').value = l.industry || '';
    document.getElementById('f_city').value = l.city || '';
    document.getElementById('f_phone').value = l.phone || '';
    document.getElementById('f_email').value = l.email || '';
    document.getElementById('f_status').value = l.status || 'New';
    document.getElementById('f_value').value = l.dealValue || '';
    document.getElementById('f_source').value = l.source || '';
    document.getElementById('f_followup').value = l.followUpDate || '';
    document.getElementById('f_notes').value = l.notes || '';
  } else {
    document.getElementById('f_name').value = '';
    document.getElementById('f_business').value = '';
    document.getElementById('f_industry').value = '';
    document.getElementById('f_city').value = '';
    document.getElementById('f_phone').value = '';
    document.getElementById('f_email').value = '';
    document.getElementById('f_status').value = 'New';
    document.getElementById('f_value').value = '';
    document.getElementById('f_source').value = '';
    document.getElementById('f_followup').value = '';
    document.getElementById('f_notes').value = '';
  }

  document.getElementById('modalOverlay').classList.add('visible');
  setTimeout(() => document.getElementById('f_name').focus(), 100);
}

function openEditModal(id) { openModal(id); }

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('visible');
}

function saveLead() {
  const name = document.getElementById('f_name').value.trim();
  const business = document.getElementById('f_business').value.trim();
  if (!name && !business) {
    document.getElementById('f_name').focus();
    return;
  }

  const editId = document.getElementById('editId').value;
  const data = {
    name, business,
    industry: document.getElementById('f_industry').value,
    city: document.getElementById('f_city').value,
    phone: document.getElementById('f_phone').value,
    email: document.getElementById('f_email').value,
    status: document.getElementById('f_status').value,
    dealValue: document.getElementById('f_value').value,
    source: document.getElementById('f_source').value,
    followUpDate: document.getElementById('f_followup').value,
    notes: document.getElementById('f_notes').value,
  };

  if (editId) {
    const idx = leads.findIndex(l => l.id === editId);
    if (idx > -1) {
      leads[idx] = { ...leads[idx], ...data, updatedAt: Date.now() };
      if (activeDrawerId === editId) openDrawer(editId);
    }
  } else {
    leads.unshift({ id: genId(), ...data, createdAt: Date.now(), activity: [] });
  }

  save();
  renderTable();
  closeModal();
}

// ── DRAWER ──
function openDrawer(id) {
  const l = leads.find(x => x.id === id);
  if (!l) return;
  activeDrawerId = id;

  document.getElementById('d_name').textContent = l.name || '—';
  document.getElementById('d_biz').textContent = l.business || '';
  document.getElementById('d_phone').textContent = l.phone || '—';
  document.getElementById('d_email').textContent = l.email || '—';
  document.getElementById('d_city').textContent = l.city || '—';
  document.getElementById('d_industry').textContent = l.industry || '—';
  document.getElementById('d_status').innerHTML = `<span class="status-pill ${STATUS_CLASS[l.status] || 's-new'}">${l.status}</span>`;
  document.getElementById('d_value').textContent = l.dealValue ? '$' + parseFloat(l.dealValue).toLocaleString() : '—';
  document.getElementById('d_source').textContent = l.source || '—';
  document.getElementById('d_followup').textContent = l.followUpDate || '—';
  document.getElementById('d_notes_text').textContent = l.notes || 'No notes yet.';

  const activity = (l.activity || []).slice().reverse();
  document.getElementById('d_activity').innerHTML = activity.length
    ? activity.map(a => `<div class="activity-item"><div class="activity-date">${new Date(a.date).toLocaleString()}</div><div class="activity-note">${a.note}</div></div>`).join('')
    : '<div style="font-family:\'DM Mono\',monospace;font-size:10px;color:var(--gray);">No activity yet</div>';

  document.getElementById('leadDrawer').classList.add('open');
  document.getElementById('drawerOverlay').classList.add('visible');
}

function closeDrawer() {
  document.getElementById('leadDrawer').classList.remove('open');
  document.getElementById('drawerOverlay').classList.remove('visible');
  activeDrawerId = null;
}

function editFromDrawer() {
  if (activeDrawerId) {
    closeDrawer();
    openModal(activeDrawerId);
  }
}

function addNote() {
  const input = document.getElementById('newNoteInput');
  const note = input.value.trim();
  if (!note || !activeDrawerId) return;

  const l = leads.find(x => x.id === activeDrawerId);
  if (!l) return;
  if (!l.activity) l.activity = [];
  l.activity.push({ date: Date.now(), note });
  save();
  input.value = '';
  openDrawer(activeDrawerId);
}

function markFollowedUp() {
  if (!activeDrawerId) return;
  const l = leads.find(x => x.id === activeDrawerId);
  if (!l) return;
  if (!l.activity) l.activity = [];
  l.activity.push({ date: Date.now(), note: 'Marked as followed up' });
  // Set next follow-up to 7 days from now
  const next = new Date();
  next.setDate(next.getDate() + 7);
  l.followUpDate = next.toISOString().split('T')[0];
  save();
  renderTable();
  openDrawer(activeDrawerId);
}

function deleteLead() {
  if (!activeDrawerId) return;
  if (confirm('Delete this lead? This cannot be undone.')) {
    leads = leads.filter(l => l.id !== activeDrawerId);
    save();
    closeDrawer();
    renderTable();
  }
}

function confirmDelete(id) {
  if (confirm('Delete this lead?')) {
    leads = leads.filter(l => l.id !== id);
    save();
    renderTable();
  }
}

// ── INIT ──
async function init() {
  await loadLeads();
  renderTable();
  renderPipeline();
  renderStats();

  if (leads.length === 0 && !getKey()) {
    const samples = [
      { id: genId(), name: 'Kristel Liska', business: 'The Grind Coffee', industry: 'Restaurant / Hospitality', city: 'Juneau, AK', phone: '', email: '', status: 'Follow-Up', dealValue: 1000, source: 'Personal Connection', followUpDate: new Date().toISOString().split('T')[0], notes: 'Warm personal connection.', activity: [], createdAt: Date.now() - 86400000 * 3 },
      { id: genId(), name: 'Austin Paul', business: 'Design North Roofing', industry: 'Roofing / Construction', city: 'Juneau, AK', phone: '', email: '', status: 'Follow-Up', dealValue: 1000, source: 'Personal Connection', followUpDate: new Date().toISOString().split('T')[0], notes: 'Warm personal connection.', activity: [], createdAt: Date.now() - 86400000 * 3 },
      { id: genId(), name: 'Dr. Taylor Haley', business: 'Haley Optical', industry: 'Optometry / Eye Care', city: 'Rapid City, SD', phone: '', email: '', status: 'Assessment Scheduled', dealValue: 1000, source: 'Personal Connection', followUpDate: '', notes: 'Practice audit scheduled.', activity: [], createdAt: Date.now() - 86400000 * 10 },
    ];
    leads = samples;
    save();
    renderTable();
    renderPipeline();
    renderStats();
  }
}

init();
</script>

