<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kodiak — Lead Tracker</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #0B0B0B; color: #FFFFFF; font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif; min-height: 100vh; }
.app-header { position: sticky; top: 0; z-index: 100; background: rgba(11,11,11,0.97); border-bottom: 1px solid rgba(198,168,90,0.15); padding: 0 20px; display: flex; align-items: center; justify-content: space-between; height: 54px; }
.brand { display: flex; align-items: center; gap: 10px; }
.brand-name { font-family: 'Courier New', monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.3em; color: #C6A85A; }
.brand-sep { width: 1px; height: 14px; background: rgba(198,168,90,0.2); }
.brand-tool { font-family: 'Courier New', monospace; font-size: 10px; letter-spacing: 0.15em; color: #666; text-transform: uppercase; }
.header-right { display: flex; align-items: center; gap: 10px; }
.add-btn { background: #C6A85A; color: #0B0B0B; border: none; border-radius: 3px; padding: 8px 18px; font-family: 'Courier New', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; }
.add-btn:hover { background: #E0C97A; }
.back-link { font-family: 'Courier New', monospace; font-size: 10px; color: #555; text-decoration: none; }
.back-link:hover { color: #C6A85A; }
.stats-bar { display: flex; gap: 1px; background: #1A1A1A; border-bottom: 1px solid rgba(198,168,90,0.1); }
.stat { flex: 1; padding: 12px 16px; background: #111; text-align: center; }
.stat-num { font-size: 22px; font-weight: 800; color: #C6A85A; line-height: 1; }
.stat-label { font-family: 'Courier New', monospace; font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; color: #444; margin-top: 3px; }
.pipeline-wrap { overflow-x: auto; background: #0d0d0d; border-bottom: 1px solid rgba(198,168,90,0.08); padding: 10px 16px; }
.pipeline-strip { display: flex; gap: 6px; min-width: max-content; }
.stage-btn { background: #1A1A1A; border: 1px solid rgba(255,255,255,0.05); border-radius: 3px; padding: 6px 12px; cursor: pointer; text-align: center; transition: all 0.2s; min-width: 90px; }
.stage-btn:hover, .stage-btn.active { border-color: #C6A85A; background: rgba(198,168,90,0.08); }
.stage-count { font-size: 16px; font-weight: 800; color: #C6A85A; line-height: 1; }
.stage-name { font-family: 'Courier New', monospace; font-size: 8px; color: #666; letter-spacing: 0.06em; margin-top: 2px; white-space: nowrap; }
.toolbar { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.04); flex-wrap: wrap; }
.search-wrap { position: relative; flex: 1; min-width: 160px; }
.search-input { width: 100%; background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; padding: 8px 12px 8px 32px; font-size: 13px; color: #FFF; outline: none; }
.search-input:focus { border-color: #C6A85A; }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #444; font-size: 13px; }
.filter-select { background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; padding: 8px 10px; font-size: 12px; color: #999; outline: none; cursor: pointer; }
.filter-select:focus { border-color: #C6A85A; }
.toolbar-count { font-family: 'Courier New', monospace; font-size: 10px; color: #444; white-space: nowrap; }
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; }
th { font-family: 'Courier New', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: #444; padding: 10px 14px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.04); background: #0d0d0d; white-space: nowrap; }
td { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; }
.lead-row { cursor: pointer; transition: background 0.15s; }
.lead-row:hover { background: rgba(198,168,90,0.04); }
.lead-name { font-size: 14px; font-weight: 600; color: #FFF; display: block; }
.lead-biz { font-family: 'Courier New', monospace; font-size: 10px; color: #C6A85A; display: block; margin-top: 1px; }
.lead-city { font-size: 12px; color: #666; }
.pill { font-family: 'Courier New', monospace; font-size: 9px; letter-spacing: 0.06em; padding: 3px 9px; border-radius: 10px; white-space: nowrap; }
.pill-new { background: rgba(96,165,250,0.1); color: #60a5fa; }
.pill-contacted { background: rgba(167,139,250,0.1); color: #a78bfa; }
.pill-followup { background: rgba(251,191,36,0.12); color: #fbbf24; }
.pill-warm { background: rgba(251,146,60,0.12); color: #fb923c; }
.pill-callbooked { background: rgba(34,211,238,0.1); color: #22d3ee; }
.pill-assessment { background: rgba(74,222,128,0.1); color: #4ade80; }
.pill-reportout { background: rgba(198,168,90,0.15); color: #C6A85A; }
.pill-strategycall { background: rgba(244,114,182,0.1); color: #f472b6; }
.pill-proposal { background: rgba(198,168,90,0.2); color: #E0C97A; }
.pill-negotiating { background: rgba(251,191,36,0.2); color: #fbbf24; }
.pill-won { background: rgba(74,222,128,0.2); color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
.pill-lost { background: rgba(248,113,113,0.1); color: #f87171; }
.deal-val { font-family: 'Courier New', monospace; font-size: 12px; color: #C6A85A; }
.row-actions { display: flex; gap: 6px; }
.row-btn { font-family: 'Courier New', monospace; font-size: 9px; padding: 5px 10px; border-radius: 3px; background: #1A1A1A; border: 1px solid rgba(255,255,255,0.05); color: #666; cursor: pointer; transition: all 0.2s; }
.row-btn:hover { border-color: #C6A85A; color: #C6A85A; }
.row-btn.del:hover { border-color: #f87171; color: #f87171; }
.empty-state { text-align: center; padding: 60px 20px; }
.empty-icon { font-size: 36px; opacity: 0.2; margin-bottom: 10px; }
.empty-text { font-family: 'Courier New', monospace; font-size: 10px; letter-spacing: 0.15em; color: #333; text-transform: uppercase; }
.drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 150; }
.drawer-overlay.open { display: block; }
.drawer { position: fixed; right: -100%; top: 0; width: 100%; max-width: 420px; height: 100vh; background: #111; border-left: 1px solid rgba(198,168,90,0.15); z-index: 160; transition: right 0.3s ease; overflow-y: auto; }
.drawer.open { right: 0; }
.drawer-header { display: flex; align-items: flex-start; justify-content: space-between; padding: 24px 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.drawer-name { font-size: 18px; font-weight: 700; color: #FFF; }
.drawer-biz { font-family: 'Courier New', monospace; font-size: 11px; color: #C6A85A; margin-top: 3px; }
.drawer-close { background: none; border: none; color: #555; font-size: 18px; cursor: pointer; }
.drawer-close:hover { color: #FFF; }
.drawer-section { padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,0.04); }
.drawer-section-title { font-family: 'Courier New', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; color: #444; margin-bottom: 10px; }
.drawer-field { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.drawer-field-key { font-family: 'Courier New', monospace; font-size: 10px; color: #555; width: 80px; flex-shrink: 0; }
.drawer-field-val { font-size: 13px; color: #CCC; }
.drawer-field-val a { color: #C6A85A; text-decoration: none; }
.drawer-actions { display: flex; flex-direction: column; gap: 8px; padding: 16px 20px; }
.drawer-btn { padding: 11px 16px; border-radius: 3px; font-family: 'Courier New', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; text-align: center; }
.drawer-btn-primary { background: #C6A85A; color: #0B0B0B; border: none; font-weight: 700; }
.drawer-btn-secondary { background: #1A1A1A; color: #999; border: 1px solid rgba(255,255,255,0.06); }
.drawer-btn-secondary:hover { border-color: #C6A85A; color: #C6A85A; }
.drawer-btn-danger { background: #1A1A1A; color: #f87171; border: 1px solid rgba(248,113,113,0.15); }
.drawer-btn-danger:hover { border-color: #f87171; }
.status-select { width: 100%; background: #1A1A1A; border: 1px solid rgba(198,168,90,0.2); border-radius: 3px; padding: 10px 12px; font-size: 13px; color: #FFF; outline: none; cursor: pointer; margin-bottom: 4px; }
.activity-log { display: flex; flex-direction: column; gap: 8px; margin-bottom: 10px; }
.activity-item { background: #1A1A1A; border-radius: 3px; padding: 10px 12px; }
.activity-note { font-size: 12px; color: #CCC; line-height: 1.5; }
.activity-date { font-family: 'Courier New', monospace; font-size: 9px; color: #444; margin-top: 4px; }
.add-note-wrap { display: flex; gap: 8px; }
.add-note-input { flex: 1; background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; padding: 8px 12px; font-size: 12px; color: #FFF; outline: none; }
.add-note-input:focus { border-color: #C6A85A; }
.add-note-btn { background: #C6A85A; color: #0B0B0B; border: none; border-radius: 3px; padding: 8px 14px; font-family: 'Courier New', monospace; font-size: 9px; font-weight: 700; cursor: pointer; white-space: nowrap; }
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 200; align-items: flex-start; justify-content: center; padding: 16px; overflow-y: auto; }
.modal-overlay.open { display: flex; }
.modal { background: #111; border: 1px solid rgba(198,168,90,0.2); border-top: 2px solid #C6A85A; border-radius: 4px; padding: 28px 24px; width: 100%; max-width: 560px; margin: auto; }
.modal-title { font-size: 18px; font-weight: 700; color: #FFF; text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
.modal-close { background: none; border: none; color: #555; font-size: 18px; cursor: pointer; }
.modal-close:hover { color: #FFF; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
.form-group { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
.form-label { font-family: 'Courier New', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: #555; }
.form-input { background: #1A1A1A; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; padding: 10px 12px; font-size: 13px; color: #FFF; outline: none; width: 100%; transition: border-color 0.2s; font-family: -apple-system, sans-serif; }
.form-input:focus { border-color: #C6A85A; }
.form-input::placeholder { color: #333; }
textarea.form-input { resize: vertical; min-height: 80px; }
.modal-actions { display: flex; gap: 10px; margin-top: 6px; }
.btn-save { flex: 1; background: #C6A85A; color: #0B0B0B; border: none; border-radius: 3px; padding: 12px; font-family: 'Courier New', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; }
.btn-save:hover { background: #E0C97A; }
.btn-cancel { background: #1A1A1A; color: #666; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; padding: 12px 20px; font-family: 'Courier New', monospace; font-size: 11px; cursor: pointer; }
.btn-cancel:hover { border-color: #C6A85A; color: #C6A85A; }
@media(max-width: 600px) {
  .form-row { grid-template-columns: 1fr; }
  th.hm, td.hm { display: none; }
  .stats-bar .stat:nth-child(4) { display: none; }
}
</style>
</head>
<body>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-title">
      <span id="modalTitle">Add Lead</span>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <input type="hidden" id="editId" />
    <div class="form-row">
      <div class="form-group"><label class="form-label">Contact Name</label><input class="form-input" id="f_name" placeholder="First Last" /></div>
      <div class="form-group"><label class="form-label">Business Name</label><input class="form-input" id="f_business" placeholder="Company Inc." /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Industry</label>
        <select class="form-input" id="f_industry">
          <option value="">Select industry</option>
          <option>Auto Body / Collision</option><option>HVAC / Home Services</option>
          <option>Dental / Orthodontics</option><option>Optometry / Eye Care</option>
          <option>Medical / Healthcare</option><option>Law Firm / Legal</option>
          <option>Roofing / Construction</option><option>Real Estate</option>
          <option>Restaurant / Hospitality</option><option>Commercial Kitchen</option>
          <option>Refrigeration</option><option>Insurance Agency</option><option>Other</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">City / State</label><input class="form-input" id="f_city" placeholder="Rapid City, SD" /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Address</label><input class="form-input" id="f_address" placeholder="123 Main St" /></div>
      <div class="form-group"><label class="form-label">Phone</label><input class="form-input" type="tel" id="f_phone" placeholder="(605) 000-0000" /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Email</label><input class="form-input" type="email" id="f_email" placeholder="owner@business.com" /></div>
      <div class="form-group"><label class="form-label">Deal Value ($)</label><input class="form-input" type="number" id="f_value" placeholder="1000" /></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Pipeline Status</label>
        <select class="form-input" id="f_status">
          <option value="New">New</option><option value="Contacted">Contacted</option>
          <option value="Follow-Up">Follow-Up</option><option value="Warm">Warm</option>
          <option value="Call Booked">Call Booked</option><option value="Assessment Scheduled">Assessment Scheduled</option>
          <option value="Report Out">Report Out</option><option value="Strategy Call">Strategy Call</option>
          <option value="Proposal Sent">Proposal Sent</option><option value="Negotiating">Negotiating</option>
          <option value="Closed Won">Closed Won</option><option value="Closed Lost">Closed Lost</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Source</label>
        <select class="form-input" id="f_source">
          <option value="">Select source</option>
          <option>Door Knock</option><option>Warm Referral</option><option>Cold Email</option>
          <option>Cold Call</option><option>Social Media</option><option>Website</option>
          <option>Business Card</option><option>Event / Networking</option>
          <option>Personal Connection</option><option>Other</option>
        </select>
      </div>
    </div>
    <div class="form-group"><label class="form-label">Notes</label><textarea class="form-input" id="f_notes" placeholder="Key details from the conversation..."></textarea></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" onclick="saveLead()">Save Lead →</button>
    </div>
  </div>
</div>

<div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div class="drawer-header">
    <div><div class="drawer-name" id="d_name">—</div><div class="drawer-biz" id="d_biz">—</div></div>
    <button class="drawer-close" onclick="closeDrawer()">✕</button>
  </div>
  <div class="drawer-section">
    <div class="drawer-section-title">Pipeline Status</div>
    <select class="status-select" id="d_status" onchange="updateStatus(this.value)">
      <option>New</option><option>Contacted</option><option>Follow-Up</option><option>Warm</option>
      <option>Call Booked</option><option>Assessment Scheduled</option><option>Report Out</option>
      <option>Strategy Call</option><option>Proposal Sent</option><option>Negotiating</option>
      <option>Closed Won</option><option>Closed Lost</option>
    </select>
  </div>
  <div class="drawer-section">
    <div class="drawer-section-title">Contact Info</div>
    <div class="drawer-field"><span class="drawer-field-key">Industry</span><span class="drawer-field-val" id="d_industry">—</span></div>
    <div class="drawer-field"><span class="drawer-field-key">City</span><span class="drawer-field-val" id="d_city">—</span></div>
    <div class="drawer-field"><span class="drawer-field-key">Address</span><span class="drawer-field-val" id="d_address">—</span></div>
    <div class="drawer-field"><span class="drawer-field-key">Phone</span><span class="drawer-field-val" id="d_phone">—</span></div>
    <div class="drawer-field"><span class="drawer-field-key">Email</span><span class="drawer-field-val" id="d_email">—</span></div>
    <div class="drawer-field"><span class="drawer-field-key">Source</span><span class="drawer-field-val" id="d_source">—</span></div>
    <div class="drawer-field"><span class="drawer-field-key">Value</span><span class="drawer-field-val" id="d_value">—</span></div>
  </div>
  <div class="drawer-section">
    <div class="drawer-section-title">Notes</div>
    <div id="d_notes" style="font-size:13px;color:#999;line-height:1.6;">—</div>
  </div>
  <div class="drawer-section">
    <div class="drawer-section-title">Activity Log</div>
    <div class="activity-log" id="d_activity"></div>
    <div class="add-note-wrap">
      <input class="add-note-input" id="newNote" placeholder="Add a note..." onkeypress="if(event.key==='Enter')addNote()" />
      <button class="add-note-btn" onclick="addNote()">+ Note</button>
    </div>
  </div>
  <div class="drawer-actions">
    <button class="drawer-btn drawer-btn-primary" onclick="editActive()">Edit Lead</button>
    <button class="drawer-btn drawer-btn-danger" onclick="deleteActive()">Remove Lead</button>
  </div>
</div>

<header class="app-header">
  <div class="brand">
    <span class="brand-name">KODIAK</span>
    <div class="brand-sep"></div>
    <span class="brand-tool">Lead Tracker</span>
  </div>
  <div class="header-right">
    <a href="hub" class="back-link">← Hub</a>
    <button class="add-btn" onclick="openModal()">+ Add Lead</button>
  </div>
</header>

<div class="stats-bar">
  <div class="stat"><div class="stat-num" id="sTotal">0</div><div class="stat-label">Total</div></div>
  <div class="stat"><div class="stat-num" id="sActive">0</div><div class="stat-label">Active</div></div>
  <div class="stat"><div class="stat-num" id="sPipeline">$0</div><div class="stat-label">Pipeline</div></div>
  <div class="stat"><div class="stat-num" id="sWon">0</div><div class="stat-label">Won</div></div>
</div>

<div class="pipeline-wrap"><div class="pipeline-strip" id="pipelineStrip"></div></div>

<div class="toolbar">
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input class="search-input" id="searchInput" placeholder="Search leads..." oninput="render()" />
  </div>
  <select class="filter-select" id="filterStatus" onchange="render()">
    <option value="">All Stages</option>
    <option>New</option><option>Contacted</option><option>Follow-Up</option><option>Warm</option>
    <option>Call Booked</option><option>Assessment Scheduled</option><option>Report Out</option>
    <option>Strategy Call</option><option>Proposal Sent</option><option>Negotiating</option>
    <option>Closed Won</option><option>Closed Lost</option>
  </select>
  <select class="filter-select" id="sortBy" onchange="render()">
    <option value="newest">Newest</option>
    <option value="value">Highest Value</option>
    <option value="name">Name A-Z</option>
    <option value="status">By Stage</option>
  </select>
  <span class="toolbar-count" id="tCount">0 leads</span>
</div>

<div class="table-wrap">
  <table>
    <thead><tr>
      <th>Lead</th><th>Status</th>
      <th class="hm">Industry</th><th class="hm">City</th>
      <th>Value</th><th></th>
    </tr></thead>
    <tbody id="tbody"></tbody>
  </table>
  <div class="empty-state" id="emptyState" style="display:none;">
    <div class="empty-icon">📋</div>
    <div class="empty-text">No leads yet — add your first one</div>
  </div>
</div>

<script>
const SB = 'https://flhnntxmikmppcoucdky.supabase.co';
const key = () => localStorage.getItem('kodiak_supabase_key') || '';
const STAGES = ['New','Contacted','Follow-Up','Warm','Call Booked','Assessment Scheduled','Report Out','Strategy Call','Proposal Sent','Negotiating','Closed Won','Closed Lost'];
const PILLS = {'New':'pill-new','Contacted':'pill-contacted','Follow-Up':'pill-followup','Warm':'pill-warm','Call Booked':'pill-callbooked','Assessment Scheduled':'pill-assessment','Report Out':'pill-reportout','Strategy Call':'pill-strategycall','Proposal Sent':'pill-proposal','Negotiating':'pill-negotiating','Closed Won':'pill-won','Closed Lost':'pill-lost'};
let leads = [], activeId = null;
const gid = () => Date.now().toString(36) + Math.random().toString(36).slice(2);

async function load() {
  try {
    if (!key()) { leads = JSON.parse(localStorage.getItem('kodiak_leads') || '[]'); return; }
    const r = await fetch(`${SB}/rest/v1/leads?order=created_at.desc`, { headers: { apikey: key(), Authorization: `Bearer ${key()}` } });
    if (r.ok) {
      const d = await r.json();
      leads = d.map(l => ({ id:l.id, name:l.name||'', business:l.business||'', industry:l.industry||'', city:l.city||'', address:l.address||'', phone:l.phone||'', email:l.email||'', status:l.status||'New', dealValue:l.deal_value||0, source:l.source||'', notes:l.notes||'', activity:l.activity||[], createdAt:l.created_at||Date.now() }));
    } else { leads = JSON.parse(localStorage.getItem('kodiak_leads') || '[]'); }
  } catch(e) { leads = JSON.parse(localStorage.getItem('kodiak_leads') || '[]'); }
}

async function persist() {
  localStorage.setItem('kodiak_leads', JSON.stringify(leads));
  if (!key()) return;
  try {
    await fetch(`${SB}/rest/v1/leads`, { method:'POST', headers:{ apikey:key(), Authorization:`Bearer ${key()}`, 'Content-Type':'application/json', Prefer:'resolution=merge-duplicates' }, body: JSON.stringify(leads.map(l => ({ id:l.id, name:l.name, business:l.business, industry:l.industry, city:l.city, address:l.address, phone:l.phone, email:l.email, status:l.status, deal_value:parseFloat(l.dealValue)||0, source:l.source, notes:l.notes, activity:l.activity||[], created_at:l.createdAt }))) });
  } catch(e) {}
}

function render() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const st = document.getElementById('filterStatus').value;
  const so = document.getElementById('sortBy').value;
  let f = leads.filter(l => (!st || l.status === st) && (!q || (l.name+l.business+l.city+l.industry).toLowerCase().includes(q)));
  if (so === 'value') f.sort((a,b)=>(b.dealValue||0)-(a.dealValue||0));
  else if (so === 'name') f.sort((a,b)=>(a.name||'').localeCompare(b.name||''));
  else if (so === 'status') f.sort((a,b)=>STAGES.indexOf(a.status)-STAGES.indexOf(b.status));
  else f.sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));

  const active = leads.filter(l=>l.status!=='Closed Won'&&l.status!=='Closed Lost').length;
  const pip = leads.filter(l=>l.status!=='Closed Lost').reduce((s,l)=>s+(parseFloat(l.dealValue)||0),0);
  document.getElementById('sTotal').textContent = leads.length;
  document.getElementById('sActive').textContent = active;
  document.getElementById('sPipeline').textContent = '$'+pip.toLocaleString();
  document.getElementById('sWon').textContent = leads.filter(l=>l.status==='Closed Won').length;

  const cnt = {};
  STAGES.forEach(s=>cnt[s]=0);
  leads.forEach(l=>{ if(cnt[l.status]!==undefined) cnt[l.status]++; });
  const cur = document.getElementById('filterStatus').value;
  document.getElementById('pipelineStrip').innerHTML = STAGES.map(s=>`<div class="stage-btn ${cur===s?'active':''}" onclick="filterStage('${s}')"><div class="stage-count">${cnt[s]}</div><div class="stage-name">${s}</div></div>`).join('');

  document.getElementById('tCount').textContent = `${f.length} lead${f.length!==1?'s':''}`;
  const empty = document.getElementById('emptyState');
  const tbody = document.getElementById('tbody');
  if (!f.length) { tbody.innerHTML=''; empty.style.display='block'; return; }
  empty.style.display='none';
  tbody.innerHTML = f.map(l=>`
    <tr class="lead-row" onclick="openDrawer('${l.id}')">
      <td><span class="lead-name">${l.name||'—'}</span><span class="lead-biz">${l.business||''}</span></td>
      <td><span class="pill ${PILLS[l.status]||'pill-new'}">${l.status}</span></td>
      <td class="hm"><span class="lead-city">${l.industry||'—'}</span></td>
      <td class="hm"><span class="lead-city">${l.city||'—'}</span></td>
      <td><span class="deal-val">${l.dealValue?'$'+parseFloat(l.dealValue).toLocaleString():'—'}</span></td>
      <td onclick="event.stopPropagation()"><div class="row-actions">
        <button class="row-btn" onclick="openModal('${l.id}')">Edit</button>
        <button class="row-btn del" onclick="del('${l.id}')">✕</button>
      </div></td>
    </tr>`).join('');
}

function filterStage(s) { const el=document.getElementById('filterStatus'); el.value=el.value===s?'':s; render(); }

function openDrawer(id) {
  activeId=id; const l=leads.find(x=>x.id===id); if(!l) return;
  document.getElementById('d_name').textContent=l.name||'—';
  document.getElementById('d_biz').textContent=l.business||'';
  document.getElementById('d_status').value=l.status||'New';
  document.getElementById('d_industry').textContent=l.industry||'—';
  document.getElementById('d_city').textContent=l.city||'—';
  document.getElementById('d_address').textContent=l.address||'—';
  document.getElementById('d_phone').innerHTML=l.phone?`<a href="tel:${l.phone}">${l.phone}</a>`:'—';
  document.getElementById('d_email').innerHTML=l.email?`<a href="mailto:${l.email}">${l.email}</a>`:'—';
  document.getElementById('d_source').textContent=l.source||'—';
  document.getElementById('d_value').textContent=l.dealValue?'$'+parseFloat(l.dealValue).toLocaleString():'—';
  document.getElementById('d_notes').textContent=l.notes||'—';
  showActivity(l);
  document.getElementById('drawerOverlay').classList.add('open');
  document.getElementById('drawer').classList.add('open');
}

function showActivity(l) {
  const log=document.getElementById('d_activity');
  if(!l.activity||!l.activity.length){log.innerHTML='<div style="font-size:12px;color:#444;font-style:italic;">No activity yet</div>';return;}
  log.innerHTML=[...l.activity].reverse().map(a=>`<div class="activity-item"><div class="activity-note">${a.note}</div><div class="activity-date">${new Date(a.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</div></div>`).join('');
}

function closeDrawer() { document.getElementById('drawerOverlay').classList.remove('open'); document.getElementById('drawer').classList.remove('open'); activeId=null; }

function updateStatus(s) {
  const l=leads.find(x=>x.id===activeId); if(!l) return;
  const old=l.status; l.status=s;
  if(!l.activity)l.activity=[];
  l.activity.push({date:Date.now(),note:`Status: ${old} → ${s}`});
  persist(); render(); showActivity(l);
}

function addNote() {
  const inp=document.getElementById('newNote'); const note=inp.value.trim();
  if(!note||!activeId) return;
  const l=leads.find(x=>x.id===activeId); if(!l) return;
  if(!l.activity)l.activity=[];
  l.activity.push({date:Date.now(),note}); inp.value='';
  persist(); showActivity(l);
}

function editActive() { closeDrawer(); openModal(activeId); }
function deleteActive() { if(confirm('Remove this lead?')) { del(activeId); closeDrawer(); } }

function openModal(id=null) {
  const isEdit=!!id;
  document.getElementById('editId').value=id||'';
  document.getElementById('modalTitle').textContent=isEdit?'Edit Lead':'Add Lead';
  if(isEdit) {
    const l=leads.find(x=>x.id===id); if(!l) return;
    document.getElementById('f_name').value=l.name||'';
    document.getElementById('f_business').value=l.business||'';
    document.getElementById('f_industry').value=l.industry||'';
    document.getElementById('f_city').value=l.city||'';
    document.getElementById('f_address').value=l.address||'';
    document.getElementById('f_phone').value=l.phone||'';
    document.getElementById('f_email').value=l.email||'';
    document.getElementById('f_status').value=l.status||'New';
    document.getElementById('f_value').value=l.dealValue||'';
    document.getElementById('f_source').value=l.source||'';
    document.getElementById('f_notes').value=l.notes||'';
  } else {
    ['f_name','f_business','f_city','f_address','f_phone','f_email','f_value','f_notes'].forEach(i=>document.getElementById(i).value='');
    document.getElementById('f_industry').value='';
    document.getElementById('f_status').value='New';
    document.getElementById('f_source').value='';
  }
  document.getElementById('modalOverlay').classList.add('open');
  setTimeout(()=>document.getElementById('f_name').focus(),100);
}

function closeModal() { document.getElementById('modalOverlay').classList.remove('open'); }

function saveLead() {
  const name=document.getElementById('f_name').value.trim();
  const business=document.getElementById('f_business').value.trim();
  if(!name&&!business){document.getElementById('f_name').focus();return;}
  const editId=document.getElementById('editId').value;
  const data={name,business,industry:document.getElementById('f_industry').value,city:document.getElementById('f_city').value,address:document.getElementById('f_address').value,phone:document.getElementById('f_phone').value,email:document.getElementById('f_email').value,status:document.getElementById('f_status').value,dealValue:document.getElementById('f_value').value,source:document.getElementById('f_source').value,notes:document.getElementById('f_notes').value};
  if(editId){const i=leads.findIndex(l=>l.id===editId);if(i>-1)leads[i]={...leads[i],...data};}
  else leads.unshift({id:gid(),...data,activity:[],createdAt:Date.now()});
  persist(); render(); closeModal();
}

function del(id) {
  if(!confirm('Remove this lead?')) return;
  leads=leads.filter(l=>l.id!==id); persist(); render();
}

async function init() {
  await load();
  if(!leads.length) {
    leads=[
      {id:gid(),name:"Marv's Body Shop",business:"Marv's Body Shop",industry:'Auto Body / Collision',city:'South Dakota',address:'',phone:'',email:'',status:'Warm',dealValue:8000,source:'Door Knock',notes:'Very interested. Multiple locations. Presentation delivered.',activity:[],createdAt:Date.now()-86400000*5},
      {id:gid(),name:'Dr. Taylor Haley',business:'Haley Optical',industry:'Optometry / Eye Care',city:'Rapid City, SD',address:'',phone:'',email:'',status:'Assessment Scheduled',dealValue:1000,source:'Personal Connection',notes:'Practice audit scheduled.',activity:[],createdAt:Date.now()-86400000*10},
      {id:gid(),name:'Austin Paul',business:'Design North Roofing',industry:'Roofing / Construction',city:'Juneau, AK',address:'',phone:'',email:'',status:'Follow-Up',dealValue:1000,source:'Personal Connection',notes:'Warm personal connection. Follow up by phone.',activity:[],createdAt:Date.now()-86400000*3},
    ];
    persist();
  }
  render();
}

init();
</script>

